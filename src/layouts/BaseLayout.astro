---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title = 'Justin Doone - Marketing Strategist',
  description = 'Marketing strategist for high-trust products and complex B2B. Based in Toronto.',
  pathname = Astro.url.pathname,
  noindex = false,
  ogImage = '/og-image.png?v=12',
} = Astro.props;

const canonical = new URL(pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (function () {
        var p = window.location.pathname;
        if (p === '/' || p.indexOf('/work/') === 0 || p.indexOf('/about') === 0) {
          document.documentElement.classList.add('nav-on-dark');
        }
        if (p === '/') {
          document.documentElement.classList.add('is-home');
        }
      })();
    </script>
    <style is:inline>
      /* Critical hiding styles inline — prevents FOUC before main CSS loads */
      .hero-line { opacity: 0; }
      [data-letter-reveal] { opacity: 0; }
      [data-letter-reveal][data-letter-ready] { opacity: 1; }

      /* Portfolio gate — see #site-gate <script> below */
      body.site-locked { overflow: hidden; }
      body.site-locked > *:not(#site-gate) { filter: blur(10px); pointer-events: none; user-select: none; }
      #site-gate {
        position: fixed; inset: 0; z-index: 100000;
        background: #0a0f1a; color: #d0d6e0;
        display: flex; align-items: center; justify-content: center;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        background-image:
          radial-gradient(ellipse at top, rgba(70, 90, 130, 0.18), transparent 60%),
          repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,255,255,0.012) 2px, rgba(255,255,255,0.012) 4px);
      }
      #site-gate.unlocked { display: none; }
      #site-gate .card {
        background: #0f1626; color: #d8dee9;
        padding: 28px 28px 22px; border-radius: 8px; max-width: 440px; width: 92%;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(120, 140, 180, 0.05);
        text-align: left;
      }
      #site-gate .badge {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 10.5px; letter-spacing: 1.5px; text-transform: uppercase;
        color: #ff7a59; font-weight: 600;
        margin-bottom: 14px;
      }
      #site-gate .badge::before {
        content: ""; display: inline-block;
        width: 7px; height: 7px; border-radius: 50%;
        background: #ff7a59;
        box-shadow: 0 0 8px rgba(255, 122, 89, 0.7);
        animation: site-gate-pulse 1.8s ease-in-out infinite;
      }
      @keyframes site-gate-pulse {
        0%, 100% { opacity: 0.45; }
        50% { opacity: 1; }
      }
      #site-gate h1 {
        font: 600 19px/1.3 inherit; color: #f4f6fa;
        margin: 0 0 6px; letter-spacing: -0.3px;
      }
      #site-gate h1 .cursor {
        display: inline-block; width: 8px; height: 16px;
        background: #ff7a59; vertical-align: -2px;
        margin-left: 4px; animation: site-gate-blink 1s steps(2) infinite;
      }
      @keyframes site-gate-blink { 50% { opacity: 0; } }
      #site-gate p {
        font: 400 13px/1.55 inherit; color: #98a0b3; margin: 0 0 4px;
      }
      #site-gate p.tagline { margin-bottom: 20px; }
      #site-gate p.tagline em {
        color: #c8cfdc; font-style: normal; background: rgba(255, 122, 89, 0.12);
        padding: 1px 5px; border-radius: 3px;
      }
      #site-gate .input-row {
        display: flex; align-items: stretch; gap: 0;
        margin: 0 0 10px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 4px;
        background: #0a0f1a;
        transition: border-color 0.15s ease, box-shadow 0.15s ease;
      }
      #site-gate .input-row:focus-within {
        border-color: #ff7a59;
        box-shadow: 0 0 0 3px rgba(255, 122, 89, 0.15);
      }
      #site-gate .prompt {
        color: #ff7a59; padding: 11px 0 11px 12px;
        font-size: 14px; user-select: none;
      }
      #site-gate input[type=password] {
        flex: 1; padding: 11px 12px 11px 8px;
        border: 0; background: transparent; color: #f4f6fa;
        font: 400 14px/1 inherit;
        outline: none;
      }
      #site-gate input[type=password]::placeholder { color: #4a5468; }
      #site-gate button {
        background: #ff7a59; color: #0a0f1a; border: 0;
        padding: 11px 14px; border-radius: 4px;
        font: 600 12px/1 inherit; letter-spacing: 1.2px; text-transform: uppercase;
        cursor: pointer; width: 100%; margin-top: 0;
        transition: background 0.15s ease, transform 0.05s ease;
      }
      #site-gate button:hover { background: #ff9170; }
      #site-gate button:active { transform: translateY(1px); }
      #site-gate .err {
        color: #f87171; font-size: 12px; line-height: 1.4; min-height: 16px;
        margin: 0 0 10px; font-style: italic;
      }
      #site-gate .meta {
        display: flex; justify-content: space-between; align-items: center;
        margin-top: 18px; padding-top: 14px;
        border-top: 1px dashed rgba(255, 255, 255, 0.07);
        font-size: 10.5px; color: #4a5468; letter-spacing: 0.4px;
      }
      #site-gate .meta span { font-variant-numeric: tabular-nums; }
      #site-gate .uptime::before {
        content: ""; display: inline-block;
        width: 6px; height: 6px; border-radius: 50%;
        background: #34d399; margin-right: 6px;
        box-shadow: 0 0 6px rgba(52, 211, 153, 0.6);
      }
    </style>
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {/* Portfolio is gated — block all crawlers regardless of per-page noindex flag */}
    <meta name="robots" content="noindex,nofollow,noarchive,nosnippet,noimageindex" />
    <meta name="googlebot" content="noindex,nofollow,noarchive,nosnippet,noimageindex" />
    <meta name="referrer" content="no-referrer" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
    {import.meta.env.PROD && (
      <>
        <script is:inline>
          (function (c, l, a, r, i, t, y) {
            c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
            t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/" + i;
            y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
          })(window, document, "clarity", "script", "wtcuckhv3l");
        </script>
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-9RX181F5KL"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', 'G-9RX181F5KL', { send_page_view: false });
        </script>
      </>
    )}
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col site-locked">
    <!-- Site-wide password gate. Persists in sessionStorage for the tab.
         Password rotation: compute SHA-256 of the new password and replace the
         hash in the script below. -->
    <div id="site-gate">
      <div class="card">
        <div class="badge">Restricted area</div>
        <h1>Hold on a second<span class="cursor"></span></h1>
        <p>Justin&rsquo;s portfolio. Not public yet.</p>
        <form id="site-gate-form" autocomplete="off">
          <div class="input-row">
            <span class="prompt">$</span>
            <input type="password" id="site-gate-pw" placeholder="say the magic word" autofocus autocomplete="off" />
          </div>
          <div class="err" id="site-gate-err">&nbsp;</div>
          <button type="submit">Let me in</button>
        </form>
        <div class="meta">
          <span class="uptime">Bouncer online</span>
          <span>v0.2.1 &middot; held together with hope</span>
        </div>
      </div>
    </div>
    <script is:inline>
      (function () {
        const STORAGE_KEY = 'jd_portfolio_unlock_v1';
        // SHA-256 of the current portfolio password
        const PASSWORD_HASH = '04d3413c21fc3bc096d2fc469a99fa44b104d17ceb651ae39dd12239ad6bc813';

        async function sha256(str) {
          const buf = new TextEncoder().encode(str);
          const hash = await crypto.subtle.digest('SHA-256', buf);
          return Array.from(new Uint8Array(hash)).map((b) => b.toString(16).padStart(2, '0')).join('');
        }

        function applyState() {
          const ok = sessionStorage.getItem(STORAGE_KEY) === PASSWORD_HASH;
          const gate = document.getElementById('site-gate');
          if (!gate) return;
          if (ok) {
            document.body.classList.remove('site-locked');
            gate.classList.add('unlocked');
          } else {
            document.body.classList.add('site-locked');
            gate.classList.remove('unlocked');
          }
        }

        const REJECTIONS = [
          'Nope. Not it.',
          'That was a guess and a bad one.',
          'Cold. Like, ice cold.',
          'Are you just typing whatever?',
          'I&rsquo;m starting to think you don&rsquo;t actually know it.',
          'Three strikes and I start judging you.',
          'You ok? You&rsquo;ve been at this a while.',
          'Honestly impressive commitment to being wrong.',
        ];

        function wireForm() {
          const form = document.getElementById('site-gate-form');
          if (!form || form.dataset.wired) return;
          form.dataset.wired = '1';
          const input = document.getElementById('site-gate-pw');
          const err = document.getElementById('site-gate-err');
          let attempts = 0;
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const pw = (input.value || '').trim();
            if (!pw) return;
            const h = await sha256(pw);
            if (h === PASSWORD_HASH) {
              sessionStorage.setItem(STORAGE_KEY, h);
              applyState();
            } else {
              const msg = REJECTIONS[Math.min(attempts, REJECTIONS.length - 1)];
              err.innerHTML = msg;
              attempts++;
              input.value = '';
              input.focus();
            }
          });
        }

        // Run on initial load AND on every Astro client-router navigation, because
        // the body element is swapped between pages.
        function init() { applyState(); wireForm(); }
        init();
        document.addEventListener('astro:page-load', init);
      })();
    </script>

    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Back-to-top button -->
    <button
      type="button"
      id="backToTop"
      class="back-to-top"
      aria-label="Back to top"
    >
      <span aria-hidden="true">↑</span>
    </button>


    <script>
      import Lenis from 'lenis';
      function setupStickyCaseMeta() {
        const inline = document.getElementById('caseMetaInline');
        const sticky = document.getElementById('caseMetaSticky');
        if (!inline || !sticky) return;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              // Show sticky once inline meta has scrolled OUT of view above
              const above = e.boundingClientRect.bottom < 0;
              sticky.classList.toggle('is-visible', above);
            });
          },
          { threshold: 0, rootMargin: '-80px 0px 0px 0px' }
        );
        observer.observe(inline);
      }

      function setupAnimatedRules() {
        const rules = document.querySelectorAll(
          '.rule-top:not([data-rule-ready])'
        );
        if (!rules.length) return;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('rule-drawn');
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        rules.forEach((r) => {
          r.setAttribute('data-rule-ready', 'true');
          observer.observe(r);
        });
      }

      function setupImageCaptions() {
        // Wrap each case-body inline image in a figure with the alt as caption
        document.querySelectorAll('.case-body img:not([data-cap-ready])').forEach((img) => {
          const alt = img.getAttribute('alt');
          if (!alt) {
            img.setAttribute('data-cap-ready', 'true');
            return;
          }
          // If already inside a figure, skip
          if (img.parentElement && img.parentElement.tagName === 'FIGURE') {
            img.setAttribute('data-cap-ready', 'true');
            return;
          }
          const figure = document.createElement('figure');
          figure.className = 'case-figure';
          const caption = document.createElement('figcaption');
          caption.className = 'case-figcaption';
          caption.textContent = alt;
          img.parentNode.insertBefore(figure, img);
          figure.appendChild(img);
          figure.appendChild(caption);
          img.setAttribute('data-cap-ready', 'true');
        });
      }

      function setupBackToTop() {
        const btn = document.getElementById('backToTop');
        if (!btn || btn.dataset.btReady) return;
        btn.dataset.btReady = 'true';
        const onScroll = () => {
          btn.classList.toggle('is-visible', window.scrollY > 600);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
        btn.addEventListener('click', () => {
          // Use Lenis if active for smooth scroll, otherwise native
          if (lenisInstance) {
            lenisInstance.scrollTo(0, { duration: 1.2 });
          } else {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
        });
      }

      function setupDropcapClass() {
        // Tag each case-body with the first paragraph's first letter so
        // CSS can apply per-letter alignment adjustments for overshoot.
        document.querySelectorAll('.case-body:not([data-first])').forEach((body) => {
          const firstP = body.querySelector('p:first-of-type');
          if (!firstP) return;
          const firstChar = (firstP.textContent || '').trim().charAt(0).toUpperCase();
          if (firstChar) body.setAttribute('data-first', firstChar);
        });
      }

      function setupLetterReveal() {
        const containers = document.querySelectorAll(
          '[data-letter-reveal]:not([data-letter-ready])'
        );
        if (!containers.length) return;
        containers.forEach((h) => {
          let i = 0;
          const splitNode = (node) => {
            if (node.nodeType === Node.TEXT_NODE) {
              const frag = document.createDocumentFragment();
              const text = node.textContent || '';
              // Split into runs of whitespace vs. word characters so we can
              // wrap each word in an atomic nowrap container — prevents the
              // browser from breaking mid-word at our inline-block char spans.
              const parts = text.split(/(\s+)/);
              for (const part of parts) {
                if (!part) continue;
                if (/^\s+$/.test(part)) {
                  frag.appendChild(document.createTextNode(part));
                } else {
                  const wordSpan = document.createElement('span');
                  wordSpan.className = 'letter-word';
                  for (const ch of part) {
                    const charSpan = document.createElement('span');
                    charSpan.className = 'letter-char';
                    charSpan.style.setProperty('--char-i', String(i++));
                    charSpan.textContent = ch;
                    wordSpan.appendChild(charSpan);
                  }
                  frag.appendChild(wordSpan);
                }
              }
              node.parentNode.replaceChild(frag, node);
            } else if (node.nodeType === Node.ELEMENT_NODE) {
              // recurse into element children (preserves <em> etc)
              Array.from(node.childNodes).forEach(splitNode);
            }
          };
          Array.from(h.childNodes).forEach(splitNode);
          h.setAttribute('data-letter-ready', 'true');
        });
      }

      function setupReveal() {
        const targets = document.querySelectorAll(
          '[data-reveal]:not(.in-view)'
        );
        if (!targets.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -64px 0px' }
        );

        targets.forEach((el) => observer.observe(el));
      }

      function loadInstagram() {
        if (!document.querySelector('blockquote.instagram-media')) return;
        if (window.instgrm) {
          window.instgrm.Embeds.process();
          return;
        }
        if (!document.querySelector('script[data-ig-embed]')) {
          const s = document.createElement('script');
          s.src = 'https://www.instagram.com/embed.js';
          s.async = true;
          s.dataset.igEmbed = 'true';
          document.body.appendChild(s);
        }
      }

      function setupCountUp() {
        const els = document.querySelectorAll(
          '[data-animate-value]:not([data-animated])'
        );
        if (!els.length) return;

        // Pre-set numeric values to 0 so they don't flash the final number
        els.forEach((el) => {
          const original = el.getAttribute('data-animate-value');
          const match = original.match(/^([^\d.-]*)([\d.]+)(.*)$/);
          if (!match) return;
          const prefix = match[1];
          const numberStr = match[2];
          const suffix = match[3];
          const decimals = numberStr.includes('.')
            ? numberStr.split('.')[1].length
            : 0;
          el.textContent = prefix + (0).toFixed(decimals) + suffix;
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target;
              if (el.dataset.animated) return;
              el.dataset.animated = 'true';

              const original = el.getAttribute('data-animate-value');
              const match = original.match(/^([^\d.-]*)([\d.]+)(.*)$/);
              if (!match) {
                el.textContent = original;
                observer.unobserve(el);
                return;
              }
              const prefix = match[1];
              const target = parseFloat(match[2]);
              const numberStr = match[2];
              const suffix = match[3];
              const decimals = numberStr.includes('.')
                ? numberStr.split('.')[1].length
                : 0;

              const duration = 1500;
              const start = performance.now();
              function tick(now) {
                const t = Math.min((now - start) / duration, 1);
                const eased = 1 - Math.pow(1 - t, 3);
                const value = target * eased;
                el.textContent = prefix + value.toFixed(decimals) + suffix;
                if (t < 1) requestAnimationFrame(tick);
                else el.textContent = original;
              }
              requestAnimationFrame(tick);
              observer.unobserve(el);
            });
          },
          { threshold: 0.4 }
        );

        els.forEach((el) => observer.observe(el));
      }

      // handleSplash logic moved to the inline head script — runs
      // synchronously before CSS to avoid a flash of animation on
      // repeat visits.

      function trackPageView() {
        if (typeof window.gtag === 'function') {
          window.gtag('event', 'page_view', {
            page_path: window.location.pathname + window.location.search,
            page_title: document.title,
            page_location: window.location.href,
          });
        }
      }

      function trackEvent(name, params) {
        if (typeof window.gtag === 'function') {
          window.gtag('event', name, params || {});
        }
      }

      function setupEventTracking() {
        // Contact clicks: email + LinkedIn. Captured wherever they appear.
        document.querySelectorAll('a[href^="mailto:"]:not([data-track-ready])').forEach((a) => {
          a.setAttribute('data-track-ready', 'true');
          a.addEventListener('click', () => {
            trackEvent('contact_click', {
              method: 'email',
              page_path: location.pathname,
            });
          });
        });
        document.querySelectorAll('a[href*="linkedin.com"]:not([data-track-ready])').forEach((a) => {
          a.setAttribute('data-track-ready', 'true');
          a.addEventListener('click', () => {
            trackEvent('contact_click', {
              method: 'linkedin',
              page_path: location.pathname,
            });
          });
        });

        // Case study clicks: any /work/SLUG link tags the slug + source page.
        document.querySelectorAll('a[href^="/work/"]:not([data-track-ready])').forEach((a) => {
          const href = a.getAttribute('href') || '';
          const match = href.match(/^\/work\/([^\/]+)/);
          if (!match) return;
          a.setAttribute('data-track-ready', 'true');
          a.addEventListener('click', () => {
            trackEvent('case_click', {
              case_id: match[1],
              from: location.pathname,
            });
          });
        });

        // Work index filter usage: which categories get filtered by.
        document.querySelectorAll('.filter-chip:not([data-track-ready])').forEach((c) => {
          c.setAttribute('data-track-ready', 'true');
          c.addEventListener('click', () => {
            const tag = c.getAttribute('data-filter') || '*';
            trackEvent('filter_use', {
              filter_tag: tag === '*' ? 'all' : tag,
            });
          });
        });

        // Case body read depth: fire once when 75% of the body has scrolled
        // past the bottom of the viewport. Skips if already tracked.
        const body = document.querySelector('.case-body:not([data-read-tracked])');
        if (body) {
          body.setAttribute('data-read-tracked', 'true');
          const slug = location.pathname
            .replace(/^\/work\//, '')
            .replace(/\/$/, '');
          let fired = false;
          const onScroll = () => {
            if (fired) return;
            const rect = body.getBoundingClientRect();
            const bodyTop = rect.top + window.scrollY;
            const bodyHeight = rect.height;
            if (bodyHeight === 0) return;
            const scrollBottom = window.scrollY + window.innerHeight;
            const ratio = (scrollBottom - bodyTop) / bodyHeight;
            if (ratio >= 0.75) {
              fired = true;
              trackEvent('case_read', { case_id: slug, depth: '75pct' });
              window.removeEventListener('scroll', onScroll);
            }
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }
      }

      let navScrollHandler = null;
      function setupNavContext() {
        const probeY = 40;
        const darkSections = Array.from(
          document.querySelectorAll('.dark-section, .case-hero')
        );

        function update() {
          const isDark = darkSections.some((el) => {
            const rect = el.getBoundingClientRect();
            return rect.top <= probeY && rect.bottom > probeY;
          });
          document.documentElement.classList.toggle('nav-on-dark', isDark);
          document.documentElement.classList.toggle(
            'is-scrolled',
            window.scrollY > 16
          );
        }

        update();

        if (navScrollHandler) {
          window.removeEventListener('scroll', navScrollHandler);
        }

        let ticking = false;
        navScrollHandler = () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              update();
              ticking = false;
            });
            ticking = true;
          }
        };
        window.addEventListener('scroll', navScrollHandler, { passive: true });
      }

      document.addEventListener('astro:before-preparation', (event) => {
        try {
          const path = new URL(event.to).pathname;
          const startsDark =
            path === '/' ||
            path.indexOf('/work/') === 0 ||
            path.indexOf('/about') === 0;
          document.documentElement.classList.toggle('nav-on-dark', startsDark);
          document.documentElement.classList.remove('is-scrolled');
        } catch (e) {}
      });

      // ============ LENIS SMOOTH SCROLL ============
      const prefersReducedMotion =
        window.matchMedia &&
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      let lenisInstance = null;
      function initLenis() {
        if (prefersReducedMotion) return;
        if (lenisInstance) return; // persist across navigations
        // Skip on demo pages so they can use native scroll events
        if (location.pathname.indexOf('/demos') === 0) return;
        lenisInstance = new Lenis({
          duration: 1.15,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          wheelMultiplier: 1.0,
          touchMultiplier: 1.5,
        });
        function raf(time) {
          lenisInstance.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      // ============ HERO ORB PARALLAX ============
      // Subtle cursor-tracked offset on hero orbs for depth without noise.
      function setupHeroParallax() {
        if (prefersReducedMotion) return;
        // Skip on demo pages so it doesn't fight with their custom animations
        if (location.pathname.indexOf('/demos') === 0) return;
        const hero = document.querySelector('.dark-section .hero-bg-image')
          ?.parentElement;
        if (!hero) return;
        const orbA = hero.querySelector('.hero-orb-a');
        const orbB = hero.querySelector('.hero-orb-b');
        const bg = hero.querySelector('.hero-bg-image');
        if (!orbA && !orbB && !bg) return;
        let raf = null;
        let tx = 0, ty = 0; // target
        let cx = 0, cy = 0; // current
        const onMove = (e) => {
          const rect = hero.getBoundingClientRect();
          if (e.clientY > rect.bottom || e.clientY < rect.top) return;
          // -1..1 from center
          const nx = (e.clientX / window.innerWidth) * 2 - 1;
          const ny = (e.clientY / rect.height) * 2 - 1;
          tx = nx;
          ty = ny;
          if (!raf) raf = requestAnimationFrame(tick);
        };
        function tick() {
          cx += (tx - cx) * 0.08;
          cy += (ty - cy) * 0.08;
          if (orbA) orbA.style.transform = `translate(${cx * 22}px, ${cy * 16}px)`;
          if (orbB) orbB.style.transform = `translate(${-cx * 18}px, ${-cy * 14}px)`;
          if (bg) bg.style.transform = `scale(1.04) translate(${-cx * 6}px, ${-cy * 5}px)`;
          if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
            raf = requestAnimationFrame(tick);
          } else {
            raf = null;
          }
        }
        window.addEventListener('mousemove', onMove, { passive: true });
      }

      // ============ MAGNETIC CTAS ============
      function setupMagnetic() {
        const els = document.querySelectorAll('[data-magnetic]:not([data-magnetic-ready])');
        els.forEach((el) => {
          el.setAttribute('data-magnetic-ready', 'true');
          const strength = parseFloat(el.getAttribute('data-magnetic-strength') || '0.25');
          const range = 80; // px from element edge
          let hovering = false;
          const onMove = (e) => {
            const rect = el.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            const dx = e.clientX - cx;
            const dy = e.clientY - cy;
            const dist = Math.hypot(dx, dy);
            const maxDist = Math.max(rect.width, rect.height) / 2 + range;
            if (dist < maxDist) {
              hovering = true;
              const pull = (1 - dist / maxDist) * strength;
              el.style.transform = `translate(${dx * pull}px, ${dy * pull}px)`;
            } else if (hovering) {
              hovering = false;
              el.style.transform = '';
            }
          };
          const reset = () => {
            hovering = false;
            el.style.transform = '';
          };
          window.addEventListener('mousemove', onMove, { passive: true });
          el.addEventListener('mouseleave', reset);
        });
      }

      // ============ BOOT ============
      initLenis();
      setupDropcapClass();
      setupLetterReveal();
      setupMagnetic();
      setupStickyCaseMeta();
      setupAnimatedRules();
      setupImageCaptions();
      setupBackToTop();
      setupEventTracking();
      setupHeroParallax();
      setupReveal();
      loadInstagram();
      setupCountUp();
      setupNavContext();
      // astro:after-swap fires only on SPA navigation (not initial render),
      // so we can safely add .no-splash here to suppress the entrance on
      // subsequent home visits without killing it on the first load.
      document.addEventListener('astro:after-swap', () => {
        document.documentElement.classList.add('no-splash');
      });

      document.addEventListener('astro:page-load', () => {
        // Lenis persists; just re-init the per-page systems
        setupLetterReveal();
        setupMagnetic();
        setupHeroParallax();
        setupReveal();
        loadInstagram();
        setupCountUp();
        setupNavContext();
        setupEventTracking();
        trackPageView();
      });
    </script>
  </body>
</html>
