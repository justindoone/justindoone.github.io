---
/**
 * Mockup layout that drops the live evolveetfs.com chrome (header + footer + CSS)
 * around an FAQ page body so the team can preview what the published version will
 * look like.
 *
 * Hosts at justindoone.github.io/faqs/. Gated by a client-side password (SHA-256
 * hash check + sessionStorage) and noindex'd so it doesn't get crawled.
 *
 * Password is "evolve2026". To rotate it, compute the new SHA-256 hex digest
 * (e.g. `python -c "import hashlib; print(hashlib.sha256(b'newpw').hexdigest())"`)
 * and replace PASSWORD_HASH below.
 */
// Vite's ?raw imports inline the file contents at build time, so they survive
// astro build's bundling (readFileSync at render time breaks because __dirname
// shifts inside the bundle).
import headExtra from '../data/faq-chrome/head.html?raw';
import evolveHeader from '../data/faq-chrome/header.html?raw';
import evolveFooter from '../data/faq-chrome/footer.html?raw';

interface PostNavLink { slug: string; title: string }
interface Props {
  title: string;
  /** H1 shown in the orange header-title-section banner */
  pageHeading: string;
  /** "FAQs" eyebrow above the heading (matches the existing post pattern) */
  eyebrow?: string;
  /** Optional background image URL for the page banner (used on the hub) */
  heroImage?: string;
  /** Body class to apply — must match the live Evolve theme's class for the
   *  same page type so its scoped CSS rules apply. */
  bodyClass?: string;
  /** 'hub' renders the page-template layout (banner with H1 inside).
   *  'topic' renders the single-post layout (image banner, "Back to FAQs"
   *  link, article-header H1, post date, prev/next nav). */
  pageType?: 'hub' | 'topic';
  /** For topic pages: the date shown in post-header-lower */
  postDate?: string;
  /** For topic pages: prev/next post navigation */
  prevPost?: PostNavLink | null;
  nextPost?: PostNavLink | null;
}
const {
  title,
  pageHeading,
  eyebrow,
  heroImage,
  pageType = 'hub',
  postDate,
  prevPost,
  nextPost,
  // Default to the FAQ hub's live body class; topic pages override with the post body class
  bodyClass = pageType === 'topic'
    ? 'wp-singular post-template-default single single-post single-format-standard wp-theme-framework wp-child-theme-evolve-funds-full-site desktop'
    : 'wp-singular page-template page-template-page-templates page-template-investor_education page-template-page-templatesinvestor_education-php page page-id-187887 wp-theme-framework wp-child-theme-evolve-funds-full-site desktop',
} = Astro.props;

// SHA-256("evolve2026") — change this hash to rotate the password
const PASSWORD_HASH = '41675798a414400ea55a25e680380c55634387e67788ba3f3cdfcd320b5b4e20';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow,noarchive,nosnippet,noimageindex" />
    <meta name="googlebot" content="noindex,nofollow,noarchive,nosnippet,noimageindex" />
    <meta name="bingbot" content="noindex,nofollow,noarchive,nosnippet,noimageindex" />
    <meta name="referrer" content="no-referrer" />
    <title>{title}</title>
    <meta name="description" content="Internal mockup preview. Not for external distribution." />
    <link rel="icon" type="image/x-icon" href="https://evolveetfs.com/wp-content/uploads/2017/09/cropped-evolve-favicon-32x32.png" />
    <Fragment set:html={headExtra} />
    <style is:inline>
      /* Override Evolve theme's body{opacity:0} (their CSS expects theme JS to fade it in;
         we don't load that JS) */
      body { opacity: 1 !important; }
      /* The Nitro layer adds .nitro-cover { visibility: hidden } — neutralize so SVG icons
         (logo etc.) stay visible */
      .nitro-cover { visibility: visible !important; }
      /* Lazy-loaded images on the live site have nitro-lazy class — force them visible */
      .nitro-lazy { background-image: inherit !important; }
      img.nitro-lazy { opacity: 1 !important; }

      /* Mockup-only chrome — disclosure ribbon + password gate overlay */
      .faq-mockup-ribbon {
        position: sticky;
        top: 0;
        z-index: 9999;
        background: #1B3D63;
        color: #fff;
        font: 600 12px/1.4 -apple-system, system-ui, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        padding: 8px 16px;
        text-align: center;
      }
      .faq-mockup-ribbon span { color: #F05A22; font-weight: 700; }
      #faq-gate {
        position: fixed; inset: 0; z-index: 100000;
        background: #1B3D63; color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-family: -apple-system, system-ui, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      }
      #faq-gate.unlocked { display: none; }
      #faq-gate .gate-card {
        background: #fff; color: #1B3D63;
        padding: 40px 36px; border-radius: 4px; max-width: 360px; width: 90%;
        box-shadow: 0 16px 48px rgba(0,0,0,0.3);
        text-align: center;
      }
      #faq-gate h1 { font: 700 22px/1.2 inherit; margin: 0 0 8px; color: #1B3D63; }
      #faq-gate p { font: 400 14px/1.5 inherit; color: #4a5568; margin: 0 0 20px; }
      #faq-gate input[type=password] {
        width: 100%; padding: 12px 14px; border: 1px solid #cdd3d6; border-radius: 4px;
        font-size: 15px; box-sizing: border-box; margin: 0 0 10px;
      }
      #faq-gate input[type=password]:focus { outline: 2px solid #F05A22; outline-offset: -1px; }
      #faq-gate button {
        background: #F05A22; color: #fff; border: 0; padding: 12px 24px; border-radius: 4px;
        font: 700 13px/1 inherit; letter-spacing: 1px; text-transform: uppercase; cursor: pointer;
        width: 100%;
      }
      #faq-gate button:hover { background: #d44d1b; }
      #faq-gate .err { color: #c02b0a; font-size: 13px; line-height: 1.4; min-height: 18px; margin: 0 0 10px; }
      body.faq-locked { overflow: hidden; }
      body.faq-locked > *:not(#faq-gate) { filter: blur(8px); pointer-events: none; user-select: none; }

      /* Header scroll state — mirrors the live evolveetfs.com transition.
         The theme stylesheet already has header.scrolled rules; we restate the
         critical ones inline with !important so they win regardless of cascade
         order between the cross-origin theme sheet and any per-page styles. */
      header.scrolled {
        background-color: #fff !important;
        padding: 0 !important;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        transition: background-color .25s ease, padding .25s ease;
      }
      header.scrolled a svg.img-logo { fill: #134e9b !important; max-height: 45px !important; }
      header.scrolled .navbar .collapse ul li a:link,
      header.scrolled .navbar .collapse ul li a:visited,
      header.scrolled .navbar .collapse ul li.menu-item a,
      header.scrolled .navbar .collapse ul li.menu-item span,
      header.scrolled .navbar .collapse div.newsletter-signup-wrapper a {
        color: #1d2126 !important;
      }
      header.scrolled .navbar .collapse ul#menu-top-menu li.menu-item.search-button:before {
        filter: invert(1);
      }
      /* The hamburger / language toggle stays the right color too */
      header.scrolled .nav-button { color: #1d2126 !important; }
      header.scrolled .nav-button .menu-hamburger { fill: #1d2126 !important; }
    </style>
  </head>
  <body class={`${bodyClass} faq-locked`}>
    <!-- Password gate -->
    <div id="faq-gate">
      <div class="gate-card">
        <h1>FAQ Mockup Preview</h1>
        <p>Internal preview for the Evolve marketing team. Enter the password to view.</p>
        <form id="faq-gate-form" autocomplete="off">
          <input type="password" id="faq-gate-pw" placeholder="Password" autofocus autocomplete="off" />
          <div class="err" id="faq-gate-err">&nbsp;</div>
          <button type="submit">Unlock</button>
        </form>
      </div>
    </div>

    <div class="faq-mockup-ribbon">
      <span>Mockup preview</span> · justindoone.github.io · not the live Evolve site
    </div>

    <Fragment set:html={evolveHeader} />

    <div
      class={
        pageType === 'topic'
          ? 'header-title-section product-singular-featured-image featured-image-bottom'
          : heroImage
            ? 'header-title-section blog-header product-singular-featured-image featured-image-bottom'
            : 'header-title-section product-singular-featured-image'
      }
      style={heroImage ? `background-image: url('${heroImage}') !important; background-repeat: no-repeat; background-position: center center; background-size: cover;` : ''}
    >
      {heroImage && <div class="banner-overlay"></div>}
      <div class="container">
        <div class="row">
          <div class="col-12">
            {pageType === 'hub' && (
              <Fragment>
                {eyebrow && <p style="color:#F05A22; font-size:12px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 8px;">{eyebrow}</p>}
                <h1 class="float-left">{pageHeading}</h1>
                <div class="w-100 float-left d-md-none"></div>
              </Fragment>
            )}
            {pageType === 'topic' && (
              <Fragment>
                <div class="back-to-parent-section">
                  <div class="container new">
                    <div class="row">
                      <div class="col-12">
                        <a href="/faqs/">
                          <h4>
                            <svg xmlns="http://www.w3.org/2000/svg" width="12.049" height="9.731" viewBox="0 0 12.049 9.731">
                              <g transform="translate(1364.549 1253.205) rotate(180)">
                                <line x2="11" transform="translate(1352.5 1248.343)" fill="none" stroke="#fff" stroke-width="1.5"/>
                                <path d="M0,4.246,4.284,0l4.4,4.246" transform="translate(1363.5 1244.002) rotate(90)" fill="none" stroke="#fff" stroke-width="1.5"/>
                              </g>
                            </svg>
                            Back to FAQs
                          </h4>
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
                <h1 class="article-header">{pageHeading}</h1>
                {postDate && (
                  <div class="post-header-lower">
                    <p class="post-date">{postDate}</p>
                  </div>
                )}
              </Fragment>
            )}
          </div>
        </div>
      </div>
    </div>

    <div id="content" class="site-content">
      <div class={pageType === 'topic' ? 'container page-content' : 'container page-content about-page-content'}>
        <div class="row">
          <div class="col-12">
            <slot />
          </div>
        </div>
      </div>
      {pageType === 'topic' && (prevPost || nextPost) && (
        <div class="desktop-post-nav">
          <div class="post-nav-container">
            <div class="container">
              <div class="row direction-row">
                <div class="col left">
                  {prevPost && (
                    <div class="post-nav prev-container">
                      <a href={`/faqs/${prevPost.slug}/`} class="prev-post arrow-button" aria-label={`Previous: ${prevPost.title}`} title={prevPost.title}>
                        <span class="arrow">
                          <svg xmlns="http://www.w3.org/2000/svg" width="12" height="10" viewBox="0 0 12.049 9.731">
                            <g transform="translate(1364.549 1253.205) rotate(180)">
                              <line x2="11" transform="translate(1352.5 1248.343)" fill="none" stroke="#fff" stroke-width="1.5"/>
                              <path d="M0,4.246,4.284,0l4.4,4.246" transform="translate(1363.5 1244.002) rotate(90)" fill="none" stroke="#fff" stroke-width="1.5"/>
                            </g>
                          </svg>
                        </span>
                        <span class="post-nav-label">Previous</span>
                        <span class="post-nav-title">{prevPost.title}</span>
                      </a>
                    </div>
                  )}
                </div>
                <div class="col right">
                  {nextPost && (
                    <div class="post-nav next-container">
                      <a href={`/faqs/${nextPost.slug}/`} class="next-post arrow-button" aria-label={`Next: ${nextPost.title}`} title={nextPost.title}>
                        <span class="post-nav-label">Next</span>
                        <span class="post-nav-title">{nextPost.title}</span>
                        <span class="arrow">
                          <svg xmlns="http://www.w3.org/2000/svg" width="12" height="10" viewBox="0 0 12.049 9.731">
                            <g>
                              <line x2="11" transform="translate(0 4.862)" fill="none" stroke="#fff" stroke-width="1.5"/>
                              <path d="M0,4.246,4.284,0l4.4,4.246" transform="translate(11 0) rotate(90)" fill="none" stroke="#fff" stroke-width="1.5"/>
                            </g>
                          </svg>
                        </span>
                      </a>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>

    <Fragment set:html={evolveFooter} />

    <script is:inline>
      // Header scroll transition — mirrors the live evolveetfs.com behavior.
      // Theme CSS already defines header.scrolled { background:#fff; ... } and
      // header.scrolled a svg.img-logo { fill:#134e9b }, etc. We just need to
      // add/remove the class as the user scrolls.
      (function () {
        const THRESHOLD = 60;
        const header = document.querySelector('header');
        if (!header) return;
        let raf = null;
        function update() {
          raf = null;
          const scrolled = window.scrollY > THRESHOLD;
          header.classList.toggle('scrolled', scrolled);
        }
        function onScroll() {
          if (raf == null) raf = requestAnimationFrame(update);
        }
        update();
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>

    <script is:inline define:vars={{ PASSWORD_HASH }}>
      (async function () {
        const STORAGE_KEY = 'evolve_faq_mockup_unlocked_v1';
        const PW_STORAGE = 'evolve_faq_mockup_pw_v1';
        const gate = document.getElementById('faq-gate');
        const form = document.getElementById('faq-gate-form');
        const input = document.getElementById('faq-gate-pw');
        const err = document.getElementById('faq-gate-err');

        function b64decode(s) {
          const bin = atob(s);
          const buf = new Uint8Array(bin.length);
          for (let i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
          return buf;
        }

        async function sha256(str) {
          const buf = new TextEncoder().encode(str);
          const hash = await crypto.subtle.digest('SHA-256', buf);
          return Array.from(new Uint8Array(hash))
            .map((b) => b.toString(16).padStart(2, '0'))
            .join('');
        }

        // Cache of fetched encrypted blob + derived key, per page load
        let cachedBlob = null;
        let cachedKey = null;

        async function loadBlob() {
          if (cachedBlob) return cachedBlob;
          // cache: 'no-cache' = always revalidate with the server (cheap 304 if
          // the blob is unchanged), so re-encryption propagates without forcing
          // every visitor to hard-refresh.
          const r = await fetch('/faqs/data/encrypted.json', { cache: 'no-cache' });
          if (!r.ok) throw new Error('encrypted blob load failed: ' + r.status);
          cachedBlob = await r.json();
          return cachedBlob;
        }

        async function deriveKey(password, blob) {
          if (cachedKey) return cachedKey;
          const pwBuf = new TextEncoder().encode(password);
          const salt = b64decode(blob.kdf.salt);
          const baseKey = await crypto.subtle.importKey('raw', pwBuf, { name: 'PBKDF2' }, false, ['deriveKey']);
          cachedKey = await crypto.subtle.deriveKey(
            { name: 'PBKDF2', salt, iterations: blob.kdf.iterations, hash: 'SHA-256' },
            baseKey,
            { name: 'AES-GCM', length: blob.kdf.key_length * 8 },
            false,
            ['decrypt']
          );
          return cachedKey;
        }

        async function decryptTopic(slug) {
          const blob = await loadBlob();
          const pw = sessionStorage.getItem(PW_STORAGE);
          if (!pw) throw new Error('not unlocked');
          const key = await deriveKey(pw, blob);
          const t = blob.topics[slug];
          if (!t) throw new Error('unknown slug: ' + slug);
          const iv = b64decode(t.iv);
          const ct = b64decode(t.ciphertext);
          const pt = await crypto.subtle.decrypt({ name: 'AES-GCM', iv }, key, ct);
          return JSON.parse(new TextDecoder().decode(pt));
        }

        // Expose for topic pages
        window.__faqDecrypt = decryptTopic;

        function unlock() {
          document.body.classList.remove('faq-locked');
          gate.classList.add('unlocked');
          // Tell any page-specific script we're unlocked
          window.dispatchEvent(new Event('faq-unlocked'));
        }

        // Already unlocked this session?
        if (sessionStorage.getItem(STORAGE_KEY) === PASSWORD_HASH && sessionStorage.getItem(PW_STORAGE)) {
          unlock();
          return;
        }

        const REJECTIONS = [
          'Mm-mm. Not it.',
          'Try again. I&rsquo;ll wait.',
          'Closer? Not really, no.',
          'I should mention: I am a brick wall.',
          'You&rsquo;ve been at this a minute now.',
          'Past performance does not guarantee future guesses.',
          'Have you considered asking the person who sent you this link?',
          'We have not approved your guesses for distribution.',
        ];
        let attempts = 0;
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const pw = input.value.trim();
          if (!pw) return;
          // Easter egg — if someone tries the two laziest passwords, send them
          // to the joke "did you really think that would work" page.
          if (/^(admin|password)$/i.test(pw)) {
            window.location.href = '/faqs/nice-try/?pw=' + encodeURIComponent(pw.toLowerCase());
            return;
          }
          const h = await sha256(pw);
          if (h === PASSWORD_HASH) {
            sessionStorage.setItem(STORAGE_KEY, h);
            // Stash the password so __faqDecrypt can re-derive the key on revisit
            sessionStorage.setItem(PW_STORAGE, pw);
            unlock();
          } else {
            err.innerHTML = REJECTIONS[Math.min(attempts, REJECTIONS.length - 1)];
            attempts++;
            input.value = '';
            input.focus();
          }
        });
      })();
    </script>
  </body>
</html>
