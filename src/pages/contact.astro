---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact - Justin Doone"
  description="Get in touch about consulting work, marketing strategy, or in-house roles."
>
  <section class="mx-auto max-w-4xl px-6 lg:px-12 pt-20 md:pt-32 pb-20">
    <p class="eyebrow mb-8">Contact</p>
    <h1 class="heading-display text-5xl md:text-7xl text-ink mb-12 leading-[0.95]">
      Get in touch.
    </h1>

    <div class="grid md:grid-cols-2 gap-12 rule-top pt-12">
      <div>
        <p class="eyebrow mb-4">Email</p>
        <a
          href="mailto:hello@justindoone.com"
          class="font-serif text-2xl md:text-3xl text-ink link-underline hover:text-accent transition-colors"
        >
          hello@justindoone.com
        </a>
        <p class="text-ink-soft mt-4 leading-relaxed max-w-sm">
          Best for project briefs and anything that benefits from being written down.
        </p>
      </div>

      <div>
        <p class="eyebrow mb-4">LinkedIn</p>
        <a
          href="https://www.linkedin.com/in/justindoone"
          target="_blank"
          rel="noopener"
          class="font-serif text-2xl md:text-3xl text-ink link-underline hover:text-accent transition-colors"
        >
          /in/justindoone
        </a>
        <p class="text-ink-soft mt-4 leading-relaxed max-w-sm">
          Easiest place to reach me if you want to chat first.
        </p>
      </div>
    </div>

    <div class="rule-top mt-16 pt-12">
      <p class="eyebrow mb-4">Currently</p>
      <p class="text-lg text-ink-soft leading-relaxed max-w-2xl">
        Open to consulting work and the right in-house role. Most interesting to me right now: financial services, B2B, and product categories that take some explaining.
      </p>
    </div>
  </section>
</BaseLayout>
