---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Demo: word reassembly - Justin Doone"
  description="Hero entrance mockup"
  noindex={true}
>
  <section class="demo-hero dark-section relative pt-24 md:pt-36 pb-24 md:pb-32">
    <div class="hero-bg-image"></div>
    <div class="hero-bg-overlay"></div>
    <div class="hero-orb hero-orb-b" style="bottom: -10%; left: 5%; opacity: 0.25; background: radial-gradient(circle, var(--color-accent-cool), transparent 60%);"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">
      <p class="wr-line eyebrow mb-8">Toronto. Marketing strategist.</p>
      <h1 class="wr-line heading-display text-5xl md:text-7xl lg:text-8xl max-w-5xl mb-10" data-wr-h1 style="color: var(--color-on-dark);">
        <span data-wr-text>Marketing for </span><em data-wr-text style="color: var(--color-accent); font-style: italic;">financial services</em><span data-wr-text> and complex B2B.</span>
      </h1>
      <p class="wr-line text-lg md:text-xl max-w-3xl leading-relaxed mb-6" style="color: var(--color-on-dark);">
        I write the copy and run the paid campaigns. The dashboards fall to me too because the teams I've been on have run lean and someone has to wire them up.
      </p>
      <p class="wr-line text-lg md:text-xl max-w-2xl leading-relaxed mb-12" style="color: var(--color-on-dark-soft);">
        Currently at Evolve ETFs, running digital marketing on the 41-fund lineup. Greybrook Realty Partners, Clifton Blake Asset Management, and Hong Kong financial communications before that.
      </p>
      <p class="wr-line"><a href="/demos" class="link-underline text-sm" style="color: var(--color-on-dark-soft);">← Back to mockups</a></p>
    </div>
  </section>

  <style is:inline>
    .wr-line { opacity: 0; }
    [data-wr-h1] { opacity: 0; }
    [data-wr-h1][data-wr-ready] { opacity: 1; }
    .wr-char {
      display: inline-block;
      opacity: 0;
      transform: translate(var(--dx, 0px), var(--dy, 0px)) rotate(var(--rot, 0deg));
      animation: wr-assemble 0.95s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      animation-delay: calc(var(--char-i, 0) * 22ms + 0.15s);
    }
    .wr-word { display: inline-block; white-space: nowrap; }
    @keyframes wr-assemble {
      to { opacity: 1; transform: translate(0, 0) rotate(0); }
    }
    .wr-line[data-line-i] {
      opacity: 0;
      transform: translateY(16px);
      animation: wr-line-in 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .wr-line[data-line-i="0"] { animation-delay: 0.05s; }
    .wr-line[data-line-i="1"] { animation-delay: 1.5s; }
    .wr-line[data-line-i="2"] { animation-delay: 1.7s; }
    .wr-line[data-line-i="3"] { animation-delay: 1.85s; }
    @keyframes wr-line-in {
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <script is:inline>
    (function () {
      const lines = document.querySelectorAll('.wr-line');
      let li = 0;
      lines.forEach((l) => {
        if (l.hasAttribute('data-wr-h1')) return;
        l.setAttribute('data-line-i', String(li++));
      });

      const h1 = document.querySelector('[data-wr-h1]');
      if (!h1) return;
      let i = 0;
      const rand = (min, max) => min + Math.random() * (max - min);
      const splitNode = (node) => {
        if (node.nodeType === Node.TEXT_NODE) {
          const text = node.textContent || '';
          const frag = document.createDocumentFragment();
          const parts = text.split(/(\s+)/);
          parts.forEach((part) => {
            if (!part) return;
            if (/^\s+$/.test(part)) {
              frag.appendChild(document.createTextNode(part));
            } else {
              const word = document.createElement('span');
              word.className = 'wr-word';
              for (const ch of part) {
                const span = document.createElement('span');
                span.className = 'wr-char';
                span.textContent = ch;
                span.style.setProperty('--dx', rand(-90, 90).toFixed(0) + 'px');
                span.style.setProperty('--dy', rand(-40, 40).toFixed(0) + 'px');
                span.style.setProperty('--rot', rand(-8, 8).toFixed(1) + 'deg');
                span.style.setProperty('--char-i', String(i++));
                word.appendChild(span);
              }
              frag.appendChild(word);
            }
          });
          node.parentNode.replaceChild(frag, node);
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          Array.from(node.childNodes).forEach(splitNode);
        }
      };
      Array.from(h1.childNodes).forEach(splitNode);
      h1.setAttribute('data-wr-ready', 'true');
    })();
  </script>
</BaseLayout>
