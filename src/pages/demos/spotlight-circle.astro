---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Demo: spotlight circle reveal - Justin Doone"
  description="Hero entrance mockup"
  noindex={true}
>
  <section class="sp-hero dark-section relative pt-24 md:pt-36 pb-24 md:pb-32 overflow-hidden">
    <div class="hero-bg-image"></div>
    <div class="hero-bg-overlay"></div>
    <div class="hero-orb hero-orb-b" style="bottom: -10%; left: 5%; opacity: 0.25; background: radial-gradient(circle, var(--color-accent-cool), transparent 60%);"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 sp-content">
      <p class="eyebrow mb-8">Toronto. Marketing strategist.</p>
      <h1 class="heading-display text-5xl md:text-7xl lg:text-8xl max-w-5xl mb-10 text-on-dark">
        Marketing for <em class="text-accent" style="font-style: italic;">high-trust products</em> and complex B2B.
      </h1>
      <p class="text-lg md:text-xl max-w-3xl leading-relaxed mb-6 text-on-dark">
        I write the copy and run the paid campaigns. The dashboards fall to me too because the teams I've been on have run lean and someone has to wire them up.
      </p>
      <p class="text-lg md:text-xl max-w-2xl leading-relaxed mb-12 text-on-dark-soft">
        Currently at Evolve ETFs, running digital marketing on the 41-fund lineup. Greybrook Realty Partners, Clifton Blake Asset Management, and Hong Kong financial communications before that.
      </p>
    </div>
  </section>

  <!-- Single overlay with a circle clip-path that grows from a small
       point near upper-left toward the viewport corners. -->
  <div class="sp-overlay" aria-hidden="true"></div>

  <style is:inline>
    /* Mask-image gradient with two interpolatable keyframes. The transparent
       portion of the gradient is the "hole" in the overlay through which
       the hero shows; that hole grows from 0 to fill the viewport. */
    .sp-overlay {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      background-color: var(--color-paper);
      z-index: 90;
      pointer-events: none;
      -webkit-mask-image: radial-gradient(circle at center, transparent 0%, transparent 0.5%, black 1%);
      mask-image: radial-gradient(circle at center, transparent 0%, transparent 0.5%, black 1%);
      animation: sp-grow 1.7s cubic-bezier(0.7, 0, 0.2, 1) forwards;
    }
    @keyframes sp-grow {
      0% {
        -webkit-mask-image: radial-gradient(circle at center, transparent 0%, transparent 0.5%, black 1%);
        mask-image: radial-gradient(circle at center, transparent 0%, transparent 0.5%, black 1%);
      }
      100% {
        -webkit-mask-image: radial-gradient(circle at center, transparent 0%, transparent 150%, black 150.5%);
        mask-image: radial-gradient(circle at center, transparent 0%, transparent 150%, black 150.5%);
      }
    }
    .sp-content {
      opacity: 0;
      animation: sp-content-in 1.2s 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes sp-content-in {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .sp-overlay { display: none; }
      .sp-content { animation: none; opacity: 1; }
    }
  </style>
</BaseLayout>
