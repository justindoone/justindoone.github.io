---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Demo: center-out letter rise - Justin Doone"
  description="Hero entrance mockup"
  noindex={true}
>
  <section class="demo-hero dark-section relative pt-24 md:pt-36 pb-24 md:pb-32">
    <div class="hero-bg-image"></div>
    <div class="hero-bg-overlay"></div>
    <div class="hero-orb hero-orb-b" style="bottom: -10%; left: 5%; opacity: 0.25; background: radial-gradient(circle, var(--color-accent-cool), transparent 60%);"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">
      <p class="lcr-line eyebrow mb-8">Toronto. Marketing strategist.</p>
      <h1 class="lcr-line heading-display text-5xl md:text-7xl lg:text-8xl max-w-5xl mb-10" data-lcr-h1 style="color: var(--color-on-dark);">
        <span data-lcr-text>Marketing for </span><em data-lcr-text style="color: var(--color-accent); font-style: italic;">financial services</em><span data-lcr-text> and complex B2B.</span>
      </h1>
      <p class="lcr-line text-lg md:text-xl max-w-3xl leading-relaxed mb-6" style="color: var(--color-on-dark);">
        I write the copy and run the paid campaigns. The dashboards fall to me too because the teams I've been on have run lean and someone has to wire them up.
      </p>
      <p class="lcr-line text-lg md:text-xl max-w-2xl leading-relaxed mb-12" style="color: var(--color-on-dark-soft);">
        Currently at Evolve ETFs, running digital marketing on the 41-fund lineup. Greybrook Realty Partners, Clifton Blake Asset Management, and Hong Kong financial communications before that.
      </p>
    </div>
  </section>

  <style is:inline>
    .lcr-line { opacity: 0; }
    [data-lcr-h1] { opacity: 0; }
    [data-lcr-h1][data-lcr-ready] { opacity: 1; }
    .lcr-char {
      display: inline-block;
      opacity: 0;
      transform: translateY(0.6em);
      animation: lcr-rise 1.1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: calc(var(--d, 0) * 30ms + 0.2s);
    }
    .lcr-word { display: inline-block; white-space: nowrap; }
    @keyframes lcr-rise {
      to { opacity: 1; transform: translateY(0); }
    }
    /* Line stagger: eyebrow leads, body lines start as the H1 letters
       are settling (~1.7s, just before center letters peak). */
    .lcr-line[data-line-i] {
      opacity: 0;
      transform: translateY(16px);
      animation: lcr-line-in 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .lcr-line[data-line-i="0"] { animation-delay: 0.05s; }
    .lcr-line[data-line-i="1"] { animation-delay: 1.7s; }
    .lcr-line[data-line-i="2"] { animation-delay: 1.95s; }
    @keyframes lcr-line-in {
      to { opacity: 1; transform: translateY(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .lcr-line, [data-lcr-h1], .lcr-char {
        opacity: 1 !important;
        transform: none !important;
        animation: none !important;
      }
    }
  </style>

  <script is:inline>
    (function () {
      // Tag non-H1 lines with their stagger index
      const lines = document.querySelectorAll('.lcr-line');
      let i = 0;
      lines.forEach((l) => {
        if (l.hasAttribute('data-lcr-h1')) return;
        l.setAttribute('data-line-i', String(i++));
      });

      // Split H1 letters, set --d = distance from center
      const h1 = document.querySelector('[data-lcr-h1]');
      if (!h1) return;
      const chars = [];
      const splitNode = (node) => {
        if (node.nodeType === Node.TEXT_NODE) {
          const text = node.textContent || '';
          const frag = document.createDocumentFragment();
          const parts = text.split(/(\s+)/);
          parts.forEach((part) => {
            if (!part) return;
            if (/^\s+$/.test(part)) {
              frag.appendChild(document.createTextNode(part));
            } else {
              const word = document.createElement('span');
              word.className = 'lcr-word';
              for (const ch of part) {
                const span = document.createElement('span');
                span.className = 'lcr-char';
                span.textContent = ch;
                word.appendChild(span);
                chars.push(span);
              }
              frag.appendChild(word);
            }
          });
          node.parentNode.replaceChild(frag, node);
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          Array.from(node.childNodes).forEach(splitNode);
        }
      };
      Array.from(h1.childNodes).forEach(splitNode);

      const center = (chars.length - 1) / 2;
      chars.forEach((c, idx) => {
        c.style.setProperty('--d', String(Math.abs(idx - center)));
      });

      h1.setAttribute('data-lcr-ready', 'true');
    })();
  </script>
</BaseLayout>
