---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Demo: preloader counter - Justin Doone"
  description="Hero entrance mockup"
  noindex={true}
>
  <section class="pc-hero dark-section relative pt-24 md:pt-36 pb-24 md:pb-32">
    <div class="hero-bg-image"></div>
    <div class="hero-bg-overlay"></div>
    <div class="hero-orb hero-orb-b" style="bottom: -10%; left: 5%; opacity: 0.25; background: radial-gradient(circle, var(--color-accent-cool), transparent 60%);"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 pc-content">
      <p class="eyebrow mb-8">Toronto. Marketing strategist.</p>
      <h1 class="heading-display text-5xl md:text-7xl lg:text-8xl max-w-5xl mb-10" style="color: var(--color-on-dark);">
        Marketing for <em style="color: var(--color-accent); font-style: italic;">financial services</em> and complex B2B.
      </h1>
      <p class="text-lg md:text-xl max-w-3xl leading-relaxed mb-6" style="color: var(--color-on-dark);">
        I write the copy and run the paid campaigns. The dashboards fall to me too because the teams I've been on have run lean and someone has to wire them up.
      </p>
      <p class="text-lg md:text-xl max-w-2xl leading-relaxed mb-12" style="color: var(--color-on-dark-soft);">
        Currently at Evolve ETFs, running digital marketing on the 41-fund lineup. Greybrook Realty Partners, Clifton Blake Asset Management, and Hong Kong financial communications before that.
      </p>
      <p><a href="/demos" class="link-underline text-sm" style="color: var(--color-on-dark-soft);">← Back to mockups</a></p>
    </div>
  </section>

  <!-- Preloader overlay -->
  <div class="pc-preloader" id="pcPreloader" aria-hidden="true">
    <div class="pc-counter"><span id="pcCounterNum">0</span><span class="pc-counter-pct">%</span></div>
  </div>

  <style is:inline>
    .pc-preloader {
      position: fixed;
      inset: 0;
      z-index: 200;
      background-color: var(--color-paper);
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
      padding: 6vh 8vw;
      transition: clip-path 0.9s cubic-bezier(0.7, 0, 0.2, 1);
      clip-path: inset(0 0 0 0);
    }
    .pc-preloader.is-done {
      clip-path: inset(0 0 100% 0);
    }
    .pc-counter {
      font-family: var(--font-serif);
      font-size: clamp(6rem, 18vw, 14rem);
      line-height: 0.9;
      color: var(--color-on-dark);
      letter-spacing: -0.04em;
      display: flex;
      align-items: flex-start;
      gap: 0.05em;
    }
    .pc-counter-pct {
      font-size: 0.3em;
      margin-top: 0.4em;
      color: var(--color-accent);
    }
    .pc-content {
      opacity: 0;
      animation: pc-content-in 1.2s 3.0s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes pc-content-in {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .pc-preloader { display: none; }
      .pc-content { animation: none; opacity: 1; }
    }
  </style>

  <script is:inline>
    (function () {
      const preloader = document.getElementById('pcPreloader');
      const num = document.getElementById('pcCounterNum');
      if (!preloader || !num) return;
      const start = performance.now();
      const duration = 2700; // count for 2.7s, then 0.3s pause before swipe
      function tick(now) {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 2);
        num.textContent = Math.round(eased * 100);
        if (t < 1) {
          requestAnimationFrame(tick);
        } else {
          setTimeout(() => preloader.classList.add('is-done'), 250);
          setTimeout(() => preloader.style.display = 'none', 1300);
        }
      }
      requestAnimationFrame(tick);
    })();
  </script>
</BaseLayout>
