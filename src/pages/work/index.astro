---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkCard from '../../components/WorkCard.astro';

const entries = (await getCollection('work'))
  .filter((e) => !e.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Work - Justin Doone"
  description="Case studies in financial services and complex B2B marketing."
>
  <section class="mx-auto max-w-7xl px-6 lg:px-12 pt-20 md:pt-32 pb-12">
    <p class="hero-line eyebrow mb-8" data-line="0">Work</p>
    <h1 class="hero-line heading-display text-5xl md:text-7xl text-ink mb-10 leading-[0.95] max-w-4xl" data-line="1">
      Case studies.
    </h1>
    <p class="hero-line text-lg text-ink-soft max-w-2xl leading-relaxed" data-line="2">
      Recent and ongoing work across financial services and complex B2B. Most projects sit across brand and performance, since the teams I've been on have been too small to keep those two separate.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-6 lg:px-12 pb-24">
    {
      entries.map((entry, i) => (
        <div data-reveal data-reveal-delay={Math.min(i + 1, 4)}>
          <WorkCard
            title={entry.data.title}
            client={entry.data.client}
            role={entry.data.role}
            date={entry.data.date}
            summary={entry.data.summary}
            href={`/work/${entry.id}`}
            tags={entry.data.tags}
            accent={entry.data.accent}
            accentSecondary={entry.data.accentSecondary}
            cover={entry.data.cover}
            index={i}
          />
        </div>
      ))
    }
    <div class="rule-top"></div>
  </section>
</BaseLayout>
