---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialEmbed from '../../components/SocialEmbed.astro';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const all = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order
);
const idx = all.findIndex((e) => e.id === entry.id);
const next = all[(idx + 1) % all.length];
const num = String(entry.data.order).padStart(2, '0');
---

<BaseLayout
  title={`${entry.data.title} - Justin Doone`}
  description={entry.data.summary}
>
  <article>
    <!-- HERO (dark only — cover image renders below the meta strip) -->
    <section class="case-hero pt-32 md:pt-44 pb-24 md:pb-36">
      <span class="case-hero-num" aria-hidden="true">{num}</span>
      <div class="mx-auto max-w-5xl px-6 lg:px-12">
        <a
          href="/work"
          class="eyebrow inline-block mb-8 opacity-70 hover:opacity-100 transition-opacity"
          style="color: var(--color-on-dark);"
        >
          ← All work
        </a>
        <p
          class="eyebrow mb-6 flex flex-wrap gap-x-3 opacity-80"
          style="color: var(--color-on-dark);"
        >
          <span>{entry.data.client}</span>
          <span class="opacity-50">/</span>
          <span>{entry.data.date}</span>
        </p>
        <h1
          class="heading-display text-5xl md:text-7xl lg:text-8xl mb-10 leading-[0.95]"
          style="color: var(--color-on-dark);"
        >
          {entry.data.title}
        </h1>
        <p
          class="text-xl md:text-2xl leading-relaxed max-w-3xl opacity-90"
          style="color: var(--color-on-dark);"
        >
          {entry.data.summary}
        </p>
      </div>
    </section>

    <!-- COVER IMAGE (constrained, max 60vh tall, preserves aspect) -->
    {
      entry.data.cover && (
        <section
          class="mx-auto max-w-5xl px-6 lg:px-12 pt-12 md:pt-16"
          data-reveal
        >
          <div class="overflow-hidden shadow-xl bg-paper-soft">
            <img
              src={entry.data.cover}
              alt={entry.data.title}
              loading="lazy"
              class="block max-h-[60vh] w-auto max-w-full mx-auto"
            />
          </div>
        </section>
      )
    }

    <!-- META STRIP -->
    <section class="mx-auto max-w-4xl px-6 lg:px-12 pt-12 pb-8" data-reveal>
      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-6 text-sm"
      >
        <div>
          <p class="eyebrow mb-1.5">Company</p>
          <p class="text-ink">{entry.data.client}</p>
        </div>
        <div>
          <p class="eyebrow mb-1.5">Role</p>
          <p class="text-ink">{entry.data.role}</p>
        </div>
        <div>
          <p class="eyebrow mb-1.5">Year</p>
          <p class="text-ink">{entry.data.year}</p>
        </div>
        <div>
          <p class="eyebrow mb-1.5">Tags</p>
          <p class="text-ink">{entry.data.tags.join(', ')}</p>
        </div>
      </div>
    </section>

    {
      entry.data.metrics && entry.data.metrics.length > 0 && (
        <section class="mx-auto max-w-4xl px-6 lg:px-12 pb-12" data-reveal>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-y-8 rule-top pt-10">
            {entry.data.metrics.map((m, i) => (
              <div data-reveal data-reveal-delay={i + 1}>
                <p
                  class="heading-display text-5xl md:text-6xl mb-2 text-accent"
                >
                  {m.value}
                </p>
                <p class="eyebrow">{m.label}</p>
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- VIDEO PLAYER (if any) -->
    {
      entry.data.video && (
        <section
          class="mx-auto max-w-5xl px-6 lg:px-12 pt-4 pb-12"
          data-reveal
        >
          <div class="overflow-hidden shadow-2xl bg-paper-soft">
            <video
              controls
              preload="metadata"
              playsinline
              poster={entry.data.cover}
              class="w-full h-auto block"
            >
              <source src={entry.data.video} type="video/mp4" />
              Your browser doesn't support HTML5 video.
            </video>
          </div>
        </section>
      )
    }

    <!-- BODY -->
    <section class="mx-auto max-w-3xl px-6 lg:px-12 pt-8 pb-20" data-reveal>
      <div
        class="prose prose-lg max-w-none
          prose-headings:font-serif prose-headings:text-ink prose-headings:font-normal prose-headings:tracking-tight
          prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4
          prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-ink-soft prose-p:leading-relaxed
          prose-strong:text-ink prose-strong:font-medium
          prose-a:text-accent prose-a:no-underline hover:prose-a:underline
          prose-blockquote:border-accent prose-blockquote:text-ink
          prose-blockquote:font-serif prose-blockquote:not-italic
          prose-li:text-ink-soft
          prose-hr:border-rule"
      >
        <Content />
      </div>
    </section>

    <!-- SOCIAL EMBEDS -->
    {
      entry.data.socials && entry.data.socials.length > 0 && (
        <section
          class="mx-auto max-w-6xl px-6 lg:px-12 py-16 rule-top"
          data-reveal
        >
          <p class="eyebrow mb-10">Social</p>
          <div class="flex flex-wrap justify-center gap-10 md:gap-12">
            {entry.data.socials.map((social) => (
              <SocialEmbed
                type={social.type}
                url={social.url}
                caption={social.caption}
              />
            ))}
          </div>
        </section>
      )
    }

    <!-- NEXT -->
    <section class="mx-auto max-w-4xl px-6 lg:px-12 py-16 rule-top" data-reveal>
      <p class="eyebrow mb-4">Next case study</p>
      <a
        href={`/work/${next.id}`}
        class="group block"
      >
        <p class="eyebrow mb-2 flex flex-wrap gap-x-3">
          <span>{next.data.client}</span>
          <span class="text-rule">/</span>
          <span>{next.data.date}</span>
        </p>
        <h2 class="heading-display text-3xl md:text-5xl text-ink group-hover:text-accent transition-colors duration-300">
          {next.data.title}
          <span
            aria-hidden="true"
            class="inline-block transition-transform duration-300 group-hover:translate-x-2"
            >→</span
          >
        </h2>
      </a>
    </section>
  </article>
</BaseLayout>
