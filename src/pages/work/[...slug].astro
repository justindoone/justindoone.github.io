---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialEmbed from '../../components/SocialEmbed.astro';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const all = (await getCollection('work'))
  .filter((e) => !e.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);

// Related cases: rank others by shared tag count, fall back to chronological
const currentTags = new Set(entry.data.tags);
const related = all
  .filter((e) => e.id !== entry.id)
  .map((e) => ({
    entry: e,
    shared: e.data.tags.filter((t) => currentTags.has(t)).length,
  }))
  .sort((a, b) => {
    if (b.shared !== a.shared) return b.shared - a.shared;
    return a.entry.data.order - b.entry.data.order;
  })
  .slice(0, 3)
  .map((r) => r.entry);

const caseImage = entry.data.ogImage ?? entry.data.cover ?? entry.data.cardCover;
const caseSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: entry.data.title,
  about: entry.data.summary,
  creator: {
    '@type': 'Person',
    name: 'Justin Doone',
    url: 'https://justindoone.github.io',
  },
  ...(entry.data.client && {
    sourceOrganization: {
      '@type': 'Organization',
      name: entry.data.client,
    },
  }),
  dateCreated: String(entry.data.year),
  keywords: entry.data.tags.join(', '),
  ...(caseImage && {
    image: new URL(caseImage, Astro.site).toString(),
  }),
};
---

<BaseLayout
  title={`${entry.data.title} - Justin Doone`}
  description={entry.data.summary}
  noindex={entry.data.hidden}
  ogImage={entry.data.ogImage ?? entry.data.cover ?? entry.data.cardCover}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(caseSchema)}
  />

  <!-- Sticky case meta strip — appears when scrolled past the inline meta -->
  <div
    class="case-meta-sticky"
    id="caseMetaSticky"
    style={`--accent: ${entry.data.accent}; --accent-secondary: ${entry.data.accentSecondary ?? entry.data.accent};`}
    aria-hidden="true"
  >
    <div class="mx-auto max-w-7xl px-6 lg:px-12 flex items-center gap-6 text-xs">
      <span class="case-meta-sticky-title">{entry.data.title}</span>
      <span class="case-meta-sticky-sep" aria-hidden="true">·</span>
      <span class="case-meta-sticky-client">{entry.data.client}</span>
      <span class="case-meta-sticky-sep" aria-hidden="true">·</span>
      <span class="case-meta-sticky-year">{entry.data.year}</span>
    </div>
  </div>

  <article style={`--accent: ${entry.data.accent}; --accent-secondary: ${entry.data.accentSecondary ?? entry.data.accent};`}>
    <!-- HERO (dark only — cover image renders below the meta strip) -->
    <section class="case-hero pt-32 md:pt-44 pb-24 md:pb-36">
      <div class="mx-auto max-w-5xl px-6 lg:px-12">
        <a
          href="/work"
          class="eyebrow text-accent-secondary inline-block mb-8 opacity-70 hover:opacity-100 transition-opacity"
        >
          ← All work
        </a>
        <p class="eyebrow text-accent-secondary mb-6 flex flex-wrap gap-x-3">
          <span>{entry.data.client}</span>
          <span class="opacity-50">/</span>
          <span>{entry.data.date}</span>
        </p>
        <h1 class="heading-display text-5xl md:text-7xl lg:text-8xl mb-10 leading-[0.95] text-on-dark">
          {entry.data.title}
        </h1>
        <p class="text-xl md:text-2xl leading-relaxed max-w-3xl opacity-90 text-on-dark">
          {entry.data.summary}
        </p>
      </div>
    </section>

    <!-- COVER IMAGE (wider container, taller cap, cinematic) -->
    {
      entry.data.cover && (
        <section
          class="mx-auto max-w-7xl px-6 lg:px-12 pt-12 md:pt-16"
          data-reveal
        >
          <img
            src={entry.data.cover}
            alt={entry.data.title}
            loading="lazy"
            class="block w-full max-h-[80vh] object-cover rounded-sm shadow-2xl"
          />
        </section>
      )
    }

    <!-- META STRIP -->
    <section id="caseMetaInline" class="mx-auto max-w-4xl px-6 lg:px-12 pt-12 pb-8" data-reveal>
      <div
        class="grid grid-cols-3 gap-6 text-sm"
      >
        <div>
          <p class="eyebrow mb-1.5">Company</p>
          <p class="text-ink">{entry.data.client}</p>
        </div>
        <div>
          <p class="eyebrow mb-1.5">Role</p>
          <p class="text-ink">{entry.data.role}</p>
        </div>
        <div>
          <p class="eyebrow mb-1.5">Year</p>
          <p class="text-ink">{entry.data.year}</p>
        </div>
      </div>
    </section>

    {
      entry.data.metrics && entry.data.metrics.length > 0 && (
        <section class="mx-auto max-w-4xl px-6 lg:px-12 pb-12" data-reveal>
          <div
            class:list={[
              'gap-y-8 rule-top pt-10 grid',
              entry.data.metrics.length === 2
                ? 'grid-cols-1 sm:grid-cols-2'
                : 'grid-cols-2 md:grid-cols-3',
            ]}
          >
            {entry.data.metrics.map((m, i) => {
              const isNumeric = /^[\d.$+%-]/.test(m.value);
              return (
                <div data-reveal data-reveal-delay={i + 1}>
                  <p
                    class:list={[
                      'heading-display text-accent-secondary mb-2',
                      isNumeric
                        ? 'text-5xl md:text-6xl'
                        : 'text-3xl md:text-4xl',
                    ]}
                    data-animate-value={m.value}
                  >
                    {m.value}
                  </p>
                  <p class="eyebrow">{m.label}</p>
                </div>
              );
            })}
          </div>
        </section>
      )
    }

    <!-- VIDEO PLAYER (if any) -->
    {
      entry.data.video && (
        <section
          class="mx-auto max-w-5xl px-6 lg:px-12 pt-4 pb-12"
          data-reveal
        >
          <div class="overflow-hidden shadow-2xl bg-paper-soft">
            <video
              controls
              preload="metadata"
              playsinline
              {...(entry.data.cover ? { poster: entry.data.cover } : {})}
              class="w-full h-auto block"
            >
              <source src={entry.data.video} type="video/mp4" />
              Your browser doesn't support HTML5 video.
            </video>
          </div>
        </section>
      )
    }

    <!-- BODY -->
    <section class="mx-auto max-w-4xl px-6 lg:px-12 pt-8 pb-20" data-reveal>
      <div
        class="case-body prose prose-lg max-w-none
          prose-headings:font-serif prose-headings:text-ink prose-headings:font-normal prose-headings:tracking-tight
          prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4
          prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-ink-soft prose-p:leading-relaxed
          prose-strong:text-ink prose-strong:font-medium
          prose-blockquote:text-ink prose-blockquote:font-serif prose-blockquote:not-italic
          prose-blockquote:text-3xl md:prose-blockquote:text-4xl
          prose-blockquote:leading-[1.15] prose-blockquote:font-normal
          prose-blockquote:tracking-tight prose-blockquote:my-12
          prose-blockquote:pl-6 prose-blockquote:max-w-3xl
          prose-li:text-ink-soft
          prose-hr:border-rule"
      >
        <Content />
      </div>
    </section>

    <!-- SOCIAL EMBEDS -->
    {
      entry.data.socials && entry.data.socials.length > 0 && (
        <section
          class="mx-auto max-w-6xl px-6 lg:px-12 py-16 rule-top"
          data-reveal
        >
          <p class="eyebrow mb-10">Social</p>
          <div class="flex flex-wrap justify-center gap-10 md:gap-12">
            {entry.data.socials.map((social) => (
              <SocialEmbed
                type={social.type}
                url={social.url}
                caption={social.caption}
              />
            ))}
          </div>
        </section>
      )
    }

    <!-- RELATED CASES -->
    {related.length > 0 && (
    <section class="mx-auto max-w-7xl px-6 lg:px-12 py-16 rule-top" data-reveal>
      <p class="eyebrow mb-8">Keep reading</p>
      <div class="grid gap-8 md:grid-cols-3">
        {related.map((r) => (
          <a
            href={`/work/${r.id}`}
            class="related-card group block"
            style={`--accent: ${r.data.accent}; --accent-secondary: ${r.data.accentSecondary ?? r.data.accent};`}
          >
            <p class="eyebrow mb-3 flex flex-wrap gap-x-3">
              <span>{r.data.client}</span>
              <span class="text-rule">/</span>
              <span>{r.data.year}</span>
            </p>
            <h3 class="heading-display text-xl md:text-2xl text-ink mb-3 transition-colors duration-300 group-hover:text-[var(--accent-secondary)]">
              {r.data.title}
            </h3>
            <p class="text-ink-soft text-sm leading-relaxed line-clamp-3">
              {r.data.summary}
            </p>
          </a>
        ))}
      </div>
    </section>
    )}
  </article>
</BaseLayout>
