---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Admin - Justin Doone"
  description="Private analytics"
  noindex={true}
>
  <!-- Password gate: appears first, hides dashboard until correct password -->
  <section id="adminGate" class="admin-gate">
    <div class="admin-gate-inner">
      <p class="eyebrow mb-6">Private</p>
      <h1 class="heading-display text-3xl md:text-4xl mb-8 text-ink">Enter password</h1>
      <form id="adminGateForm" class="flex flex-col gap-4 max-w-sm">
        <input
          type="password"
          id="adminPwInput"
          class="admin-pw-input"
          placeholder="Password"
          autocomplete="current-password"
          autofocus
        />
        <button type="submit" class="admin-pw-submit">Enter</button>
        <p id="adminGateError" class="text-sm text-red-500 hidden">Wrong password.</p>
      </form>
    </div>
  </section>

  <!-- Dashboard (hidden until unlocked) -->
  <section id="adminDash" class="admin-dash hidden">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 pt-24 pb-16">

      <header class="flex flex-wrap items-end justify-between gap-4 mb-10">
        <div>
          <p class="eyebrow mb-2">Analytics</p>
          <h1 class="heading-display text-3xl md:text-4xl text-ink">Portfolio overview</h1>
        </div>
        <div class="flex items-center gap-2 text-xs">
          <span class="admin-range-label">Range:</span>
          <button class="admin-range-btn is-active" data-range="7d">7d</button>
          <button class="admin-range-btn" data-range="30d">30d</button>
          <button class="admin-range-btn" data-range="90d">90d</button>
          <button id="adminLogout" class="admin-logout-btn" aria-label="Log out">Log out</button>
        </div>
      </header>

      <!-- Loading / error banner -->
      <p id="adminStatus" class="admin-status mb-8 hidden"></p>

      <!-- KPI strip -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
        <div class="admin-kpi">
          <p class="admin-kpi-label">Visitors</p>
          <p class="admin-kpi-value" id="kpiVisitors">—</p>
          <p class="admin-kpi-delta">unique users</p>
        </div>
        <div class="admin-kpi">
          <p class="admin-kpi-label">Pageviews</p>
          <p class="admin-kpi-value" id="kpiPageviews">—</p>
          <p class="admin-kpi-delta">total views</p>
        </div>
        <div class="admin-kpi">
          <p class="admin-kpi-label">Avg session</p>
          <p class="admin-kpi-value" id="kpiAvgSession">—</p>
          <p class="admin-kpi-delta"><span id="kpiSessions">—</span> sessions</p>
        </div>
        <div class="admin-kpi">
          <p class="admin-kpi-label">Live now</p>
          <p class="admin-kpi-value">
            <span class="admin-live-dot"></span><span id="kpiLive">—</span>
          </p>
          <p class="admin-kpi-delta">last 30 min</p>
        </div>
      </div>

      <!-- Two-column: time series + geography -->
      <div class="grid md:grid-cols-3 gap-8 mb-10">
        <div class="md:col-span-2">
          <p class="eyebrow mb-3">Visitors over time</p>
          <div class="admin-card">
            <svg id="chartVisitors" viewBox="0 0 600 200" class="w-full h-auto" preserveAspectRatio="none">
              <polyline id="chartLine" points="" fill="none" stroke="var(--color-accent)" stroke-width="2" />
              <polyline id="chartArea" points="" fill="var(--color-accent)" fill-opacity="0.08" stroke="none" />
            </svg>
            <div class="flex justify-between text-xs text-ink-mute mt-3">
              <span id="chartStart">—</span><span id="chartEnd">—</span>
            </div>
          </div>
        </div>

        <div>
          <p class="eyebrow mb-3">Top locations</p>
          <div class="admin-card">
            <ul class="admin-list" id="listLocations">
              <li class="admin-empty">Loading…</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Top pages + Top sources -->
      <div class="grid md:grid-cols-2 gap-8 mb-10">
        <div>
          <p class="eyebrow mb-3">Top pages</p>
          <div class="admin-card">
            <ul class="admin-list" id="listPages">
              <li class="admin-empty">Loading…</li>
            </ul>
          </div>
        </div>

        <div>
          <p class="eyebrow mb-3">Traffic sources</p>
          <div class="admin-card">
            <ul class="admin-list" id="listSources">
              <li class="admin-empty">Loading…</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Engagement events (custom + GA4 automatic) -->
      <div class="mb-10">
        <p class="eyebrow mb-3">Engagement events</p>
        <div class="admin-card">
          <ul class="admin-list" id="listEvents">
            <li class="admin-empty">Loading…</li>
          </ul>
        </div>
      </div>

      <!-- Recent activity log -->
      <div>
        <p class="eyebrow mb-3">Recent activity</p>
        <div class="admin-card">
          <table class="admin-table">
            <thead>
              <tr><th>Time</th><th>Location</th><th>Page</th><th>Source</th></tr>
            </thead>
            <tbody id="tableRecent">
              <tr><td colspan="4" class="admin-empty">Loading…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <style is:inline>
    /* Hide demo controls + back-to-top + nav on this page — admin standalone */
    body { background-color: var(--color-paper); }

    .admin-gate {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    /* Explicit .hidden overrides — beats Tailwind's lower-specificity
       .hidden rule that was being trumped by .admin-gate's display:flex */
    .admin-gate.hidden,
    .admin-dash.hidden {
      display: none;
    }
    .admin-gate-inner {
      max-width: 400px;
      width: 100%;
    }
    .admin-pw-input {
      background-color: var(--color-paper-soft);
      border: 1px solid var(--color-rule);
      color: var(--color-ink);
      padding: 0.85rem 1rem;
      font-family: var(--font-mono);
      font-size: 0.9rem;
      letter-spacing: 0.02em;
      outline: none;
      transition: border-color 0.2s ease;
    }
    .admin-pw-input:focus {
      border-color: var(--color-accent);
    }
    .admin-pw-submit {
      background-color: var(--color-accent);
      color: var(--color-paper);
      padding: 0.7rem 1.4rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      border: none;
      transition: background-color 0.2s ease;
    }
    .admin-pw-submit:hover {
      background-color: var(--color-accent-warm);
    }

    .admin-dash {
      min-height: 100vh;
    }

    .admin-banner {
      padding: 0.85rem 1rem;
      background-color: rgba(212, 165, 116, 0.12);
      border-left: 3px solid #d4a574;
      color: var(--color-ink-soft);
      font-size: 0.85rem;
    }

    /* Status banner for loading/error messages */
    .admin-status {
      padding: 0.75rem 1rem;
      background-color: var(--color-paper-soft);
      border-left: 3px solid var(--color-rule);
      color: var(--color-ink-soft);
      font-size: 0.85rem;
      font-family: var(--font-mono);
      letter-spacing: 0.02em;
    }
    .admin-status.admin-status-error {
      border-left-color: #b94c3a;
      color: #d4837a;
    }

    /* Empty state inside list cards */
    .admin-empty {
      color: var(--color-ink-mute);
      font-style: italic;
      font-size: 0.85rem;
      padding: 0.55rem 0;
      border-bottom: none !important;
    }

    .admin-range-btn {
      padding: 0.35rem 0.75rem;
      border-radius: 9999px;
      border: 1px solid var(--color-rule);
      background: transparent;
      color: var(--color-ink-soft);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .admin-range-btn:hover { color: var(--color-ink); border-color: var(--color-ink-soft); }
    .admin-range-btn.is-active {
      background-color: var(--color-accent);
      border-color: var(--color-accent);
      color: var(--color-paper);
    }
    .admin-logout-btn {
      margin-left: 0.5rem;
      padding: 0.35rem 0.85rem;
      border-radius: 9999px;
      border: 1px solid var(--color-rule);
      background: transparent;
      color: var(--color-ink-mute);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .admin-logout-btn:hover {
      color: var(--color-ink);
      border-color: var(--color-ink-soft);
    }
    .admin-range-label {
      color: var(--color-ink-mute);
      font-family: var(--font-mono);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-right: 0.25rem;
    }

    .admin-kpi {
      padding: 1.25rem 1.5rem;
      background-color: var(--color-paper-soft);
      border: 1px solid var(--color-rule);
    }
    .admin-kpi-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-ink-mute);
      margin-bottom: 0.4rem;
    }
    .admin-kpi-value {
      font-family: var(--font-serif);
      font-size: 2rem;
      line-height: 1;
      color: var(--color-ink);
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .admin-kpi-delta {
      font-size: 0.72rem;
      margin-top: 0.4rem;
      color: var(--color-ink-mute);
    }
    .admin-up { color: #87a06b; }
    .admin-down { color: #b94c3a; }
    .admin-live-dot {
      display: inline-block;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: #87a06b;
      animation: live-pulse 1.5s ease-in-out infinite;
    }
    @keyframes live-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%      { opacity: 0.5; transform: scale(0.85); }
    }

    .admin-card {
      padding: 1.5rem;
      background-color: var(--color-paper-soft);
      border: 1px solid var(--color-rule);
    }

    .admin-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .admin-list li {
      display: flex;
      justify-content: space-between;
      padding: 0.55rem 0;
      border-bottom: 1px solid var(--color-rule);
      font-size: 0.88rem;
      color: var(--color-ink);
    }
    .admin-list li:last-child { border-bottom: none; }
    .admin-list-num {
      color: var(--color-ink-mute);
      font-family: var(--font-mono);
    }

    .admin-table {
      width: 100%;
      font-size: 0.85rem;
    }
    .admin-table th {
      text-align: left;
      padding: 0.5rem 0.8rem 0.5rem 0;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-ink-mute);
      font-weight: 500;
      border-bottom: 1px solid var(--color-rule);
    }
    .admin-table td {
      padding: 0.65rem 0.8rem 0.65rem 0;
      color: var(--color-ink);
      border-bottom: 1px solid var(--color-rule);
    }
    .admin-table tr:last-child td { border-bottom: none; }
  </style>

  <script>
    // Cosmetic password gate (client-side, bypassable — for the public
    // it's just "you shouldn't be here"). The plaintext never appears
    // in the bundle, only its SHA-256 hash.
    // To change: run `python -c "import hashlib; print(hashlib.sha256('NEWPW'.encode()).hexdigest())"`
    const PASSWORD_HASH = '51f6c69911e1cd1d26d7934acd08a4fb712103f10b3e2a3a9830c40f0c3b5c37';
    // Joke traps — anyone trying these obvious guesses gets redirected
    // to /nice-try instead of the standard "wrong password" message.
    const TRAP_HASHES = [
      '8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918', // "admin"
      '5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8', // "password"
    ];

    async function sha256(text: string) {
      const buf = new TextEncoder().encode(text);
      const digest = await crypto.subtle.digest('SHA-256', buf);
      return Array.from(new Uint8Array(digest))
        .map((b) => b.toString(16).padStart(2, '0'))
        .join('');
    }

    function setupAdminGate() {
      const form = document.getElementById('adminGateForm');
      const input = document.getElementById('adminPwInput') as HTMLInputElement | null;
      const errorEl = document.getElementById('adminGateError');
      const gate = document.getElementById('adminGate');
      const dash = document.getElementById('adminDash');
      if (!form || !input || !gate || !dash) return;

      // Persist unlock for the session so reloads don't re-prompt
      if (sessionStorage.getItem('jd-admin-unlocked') === '1') {
        gate.classList.add('hidden');
        dash.classList.remove('hidden');
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const pw = input.value;
        const hash = await sha256(pw);
        if (hash === PASSWORD_HASH) {
          sessionStorage.setItem('jd-admin-unlocked', '1');
          gate.classList.add('hidden');
          dash.classList.remove('hidden');
          loadDashboard('7d');
        } else if (TRAP_HASHES.indexOf(hash) !== -1) {
          // Caught the obvious-guess attempt — redirect to the joke page
          window.location.href = '/nice-try';
        } else {
          if (errorEl) errorEl.classList.remove('hidden');
          input.value = '';
          input.focus();
        }
      });

      // Logout button on the dashboard
      const logoutBtn = document.getElementById('adminLogout');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', () => {
          sessionStorage.removeItem('jd-admin-unlocked');
          gate.classList.remove('hidden');
          dash.classList.add('hidden');
          if (input) {
            input.value = '';
            input.focus();
          }
        });
      }

      // Range buttons — change the data range and refetch
      document.querySelectorAll('.admin-range-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.admin-range-btn').forEach((b) =>
            b.classList.remove('is-active')
          );
          btn.classList.add('is-active');
          const range = btn.getAttribute('data-range') || '7d';
          loadDashboard(range);
        });
      });

      // Initial load if already unlocked
      if (sessionStorage.getItem('jd-admin-unlocked') === '1') {
        loadDashboard('7d');
      }
    }

    // ============ LIVE GA4 DATA ============
    const WORKER_URL = 'https://portfolio-analytics.justindoone.workers.dev';

    async function loadDashboard(range) {
      const statusEl = document.getElementById('adminStatus');
      setStatus(statusEl, 'Loading…', false);
      try {
        const res = await fetch(`${WORKER_URL}?range=${encodeURIComponent(range)}`, {
          method: 'GET',
          mode: 'cors',
        });
        const data = await res.json();
        if (!res.ok || data.error) {
          throw new Error(data.error || `HTTP ${res.status}`);
        }
        renderDashboard(data, range);
        setStatus(statusEl, '', false);
      } catch (err) {
        setStatus(statusEl, `Failed to load: ${(err as Error).message}`, true);
      }
    }

    function setStatus(el, msg, isError) {
      if (!el) return;
      if (!msg) {
        el.classList.add('hidden');
        el.textContent = '';
        return;
      }
      el.textContent = msg;
      el.classList.remove('hidden');
      el.classList.toggle('admin-status-error', !!isError);
    }

    function renderDashboard(data, range) {
      // KPI strip
      const ov = data.overview?.rows?.[0]?.metricValues || [];
      setText('kpiVisitors', formatNumber(parseInt(ov[0]?.value || '0')));
      setText('kpiPageviews', formatNumber(parseInt(ov[1]?.value || '0')));
      setText('kpiAvgSession', formatDuration(parseFloat(ov[2]?.value || '0')));
      setText('kpiSessions', formatNumber(parseInt(ov[3]?.value || '0')));

      // Live now
      const liveRows = data.realtime?.rows || [];
      const liveCount = liveRows.reduce((sum, r) => sum + parseInt(r.metricValues?.[0]?.value || '0'), 0);
      setText('kpiLive', String(liveCount));

      // Time series chart
      renderChart(data.timeSeries, range);

      // Top locations
      renderList('listLocations', data.locations, (row) => {
        const country = row.dimensionValues?.[0]?.value || '';
        const region = row.dimensionValues?.[1]?.value || '';
        const city = row.dimensionValues?.[2]?.value || '';
        const label = formatLocation(city, region, country);
        return { label, value: parseInt(row.metricValues?.[0]?.value || '0') };
      });

      // Top pages
      renderList('listPages', data.pages, (row) => ({
        label: row.dimensionValues?.[0]?.value || '',
        value: parseInt(row.metricValues?.[0]?.value || '0'),
      }));

      // Top sources
      renderList('listSources', data.sources, (row) => ({
        label: row.dimensionValues?.[0]?.value || '',
        value: parseInt(row.metricValues?.[0]?.value || '0'),
      }));

      // Events
      renderList('listEvents', data.events, (row) => ({
        label: row.dimensionValues?.[0]?.value || '',
        value: parseInt(row.metricValues?.[0]?.value || '0'),
      }));

      // Recent activity table
      renderRecent('tableRecent', data.recent);
    }

    function renderRecent(id, report) {
      const tbody = document.getElementById(id);
      if (!tbody) return;
      const rows = report?.rows || [];
      if (rows.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="admin-empty">No activity yet for this range.</td></tr>';
        return;
      }
      tbody.innerHTML = rows.map((row) => {
        const dvs = row.dimensionValues || [];
        const dateHourMin = dvs[0]?.value || '';
        const country = dvs[1]?.value || '';
        const region = dvs[2]?.value || '';
        const city = dvs[3]?.value || '';
        const page = dvs[4]?.value || '';
        const source = dvs[5]?.value || '';
        const loc = formatLocation(city, region, country);
        const time = formatRelativeTime(dateHourMin);
        const cleanSource = source === '(direct)' ? 'direct' : (source === '(not set)' ? '—' : source);
        return `<tr>
          <td>${escapeHtml(time)}</td>
          <td>${escapeHtml(loc)}</td>
          <td>${escapeHtml(page)}</td>
          <td>${escapeHtml(cleanSource)}</td>
        </tr>`;
      }).join('');
    }

    function formatLocation(city, region, country) {
      // Build "City, Region, Country" but drop pieces that are empty/(not set)
      const parts = [];
      if (city && city !== '(not set)') parts.push(city);
      if (region && region !== '(not set)' && region !== city) parts.push(region);
      if (country && country !== '(not set)') parts.push(country);
      return parts.length > 0 ? parts.join(', ') : 'Unknown';
    }

    function formatRelativeTime(dateHourMin) {
      // GA4 returns YYYYMMDDHHMM in the property's timezone (America/Toronto here).
      // Parsed as local time below — accurate for any viewer also in Toronto.
      if (!dateHourMin || dateHourMin.length !== 12) return '—';
      const y = parseInt(dateHourMin.slice(0, 4));
      const mo = parseInt(dateHourMin.slice(4, 6)) - 1;
      const d = parseInt(dateHourMin.slice(6, 8));
      const h = parseInt(dateHourMin.slice(8, 10));
      const mi = parseInt(dateHourMin.slice(10, 12));
      const local = new Date(y, mo, d, h, mi);
      const diff = Math.floor((Date.now() - local.getTime()) / 1000);
      if (diff < 60) return 'just now';
      if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
      if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
      if (diff < 604800) return `${Math.floor(diff / 86400)}d ago`;
      const month = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][mo];
      return `${month} ${d}`;
    }

    function setText(id, text) {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    }

    function formatNumber(n) {
      if (n >= 10000) return (n / 1000).toFixed(1) + 'K';
      return n.toLocaleString('en-US');
    }

    function formatDuration(secs) {
      if (!secs || isNaN(secs)) return '0s';
      const m = Math.floor(secs / 60);
      const s = Math.round(secs % 60);
      return m > 0 ? `${m}m ${s}s` : `${s}s`;
    }

    function renderList(id, report, mapFn) {
      const ul = document.getElementById(id);
      if (!ul) return;
      const rows = report?.rows || [];
      if (rows.length === 0) {
        ul.innerHTML = '<li class="admin-empty">No data yet for this range.</li>';
        return;
      }
      ul.innerHTML = rows.map((row) => {
        const { label, value } = mapFn(row);
        const safeLabel = escapeHtml(label);
        return `<li><span>${safeLabel}</span><span class="admin-list-num">${formatNumber(value)}</span></li>`;
      }).join('');
    }

    function renderChart(report, range) {
      const lineEl = document.getElementById('chartLine');
      const areaEl = document.getElementById('chartArea');
      const startEl = document.getElementById('chartStart');
      const endEl = document.getElementById('chartEnd');
      const rows = report?.rows || [];
      if (rows.length === 0) {
        if (lineEl) lineEl.setAttribute('points', '');
        if (areaEl) areaEl.setAttribute('points', '');
        if (startEl) startEl.textContent = '—';
        if (endEl) endEl.textContent = '—';
        return;
      }
      const values = rows.map((r) => parseInt(r.metricValues?.[0]?.value || '0'));
      const dates = rows.map((r) => r.dimensionValues?.[0]?.value || '');
      const max = Math.max(...values, 1);
      const W = 600, H = 200, padTop = 20, padBottom = 30;
      const usableH = H - padTop - padBottom;
      const points = values.map((v, i) => {
        const x = (i / Math.max(values.length - 1, 1)) * W;
        const y = padTop + usableH - (v / max) * usableH;
        return `${x.toFixed(1)},${y.toFixed(1)}`;
      }).join(' ');
      if (lineEl) lineEl.setAttribute('points', points);
      if (areaEl) areaEl.setAttribute('points', `${points} ${W},${H} 0,${H}`);
      if (startEl) startEl.textContent = formatDate(dates[0]);
      if (endEl) endEl.textContent = formatDate(dates[dates.length - 1]);
    }

    function formatDate(d) {
      // GA4 returns dates as YYYYMMDD strings
      if (!d || d.length !== 8) return '';
      const month = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][parseInt(d.slice(4, 6)) - 1];
      return `${month} ${parseInt(d.slice(6, 8))}`;
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      })[c]);
    }

    setupAdminGate();
    document.addEventListener('astro:page-load', setupAdminGate);
  </script>
</BaseLayout>
