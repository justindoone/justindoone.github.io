---
import BaseLayout from '../layouts/BaseLayout.astro';

const options = [
  {
    id: 'logo-folded',
    name: 'Mark 1 — Folded',
    desc: 'A coral square with one corner cut diagonally, like a folded page or label tag. Reads as document / strategy paper / brief. Most stable at very small sizes.',
  },
  {
    id: 'logo-asterisk',
    name: 'Mark 2 — Asterisk',
    desc: 'A custom six-arm asterisk built from three crossed coral bars at 60° angles. Reads as editorial / footnote / strategist mark. Pairs naturally with the serif headings on the site.',
  },
  {
    id: 'logo-focal',
    name: 'Mark 3 — Focal',
    desc: 'Two concentric coral outlined squares with a solid coral block deliberately off-center. Reads as focus / audience target without the generic bullseye cliché.',
  },
];
---

<BaseLayout
  title="Logo options - Justin Doone"
  description="Internal page for picking a logo direction."
>
  <section class="mx-auto max-w-7xl px-6 lg:px-12 pt-16 pb-12">
    <p class="eyebrow mb-6">Internal</p>
    <h1 class="heading-display text-4xl md:text-6xl text-ink mb-6">Logo options</h1>
    <p class="text-lg text-ink-soft max-w-2xl leading-relaxed">
      Three custom marks paired with the same wordmark. Each shown at three sizes: header (~32px), footer / signature (~64px), and hero / social share (140px). The mark is what makes it a logo rather than typography.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-6 lg:px-12 pb-32">
    {
      options.map((opt) => (
        <div class="rule-top py-12">
          <div class="grid md:grid-cols-12 gap-6 mb-8">
            <div class="md:col-span-3">
              <p class="eyebrow mb-2">{opt.name.split('—')[0].trim()}</p>
              <h2 class="font-serif text-2xl text-ink mb-3">
                {opt.name.split('—')[1]?.trim() || opt.name}
              </h2>
              <p class="text-ink-soft text-sm leading-relaxed">{opt.desc}</p>
            </div>
            <div class="md:col-span-9 space-y-6">
              <div>
                <p class="eyebrow mb-2">Small (header use ~32px)</p>
                <img
                  src={`/logos/${opt.id}.svg`}
                  alt={opt.name}
                  style="height: 32px; width: auto; display: block;"
                />
              </div>
              <div>
                <p class="eyebrow mb-2">Medium (footer / signature ~64px)</p>
                <img
                  src={`/logos/${opt.id}.svg`}
                  alt={opt.name}
                  style="height: 64px; width: auto; display: block;"
                />
              </div>
              <div>
                <p class="eyebrow mb-2">Large (hero / share card)</p>
                <img
                  src={`/logos/${opt.id}.svg`}
                  alt={opt.name}
                  style="height: 140px; width: auto; display: block;"
                />
              </div>
            </div>
          </div>
        </div>
      ))
    }

    <div class="rule-top pt-12 mt-12">
      <p class="eyebrow mb-4">When you've decided</p>
      <p class="text-lg text-ink-soft max-w-2xl leading-relaxed">
        Tell me which one (or "none of these, try a different direction") and I'll build it out into the full system: horizontal lockup, stacked variant, mark-only, plus a new favicon to match.
      </p>
    </div>
  </section>
</BaseLayout>
