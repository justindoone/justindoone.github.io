---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';

const all = await getCollection('work');
const featured = all
  .filter((w) => w.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const showcase = featured.length > 0 ? featured : all.sort((a, b) => a.data.order - b.data.order).slice(0, 4);
---

<BaseLayout>
  <!-- HERO (dark, with personal intro) -->
  <section class="dark-section relative pt-24 md:pt-36 pb-24 md:pb-32">
    <div class="hero-orb" style="top: -15%; right: -10%;"></div>
    <div class="hero-orb" style="bottom: -10%; left: 5%; opacity: 0.25; background: radial-gradient(circle, var(--color-accent-cool), transparent 60%);"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">
      <p class="hero-line eyebrow mb-8" data-line="0">Toronto. Marketing strategist.</p>
      <h1 class="hero-line heading-display text-5xl md:text-7xl lg:text-8xl max-w-5xl mb-10" data-line="1" style="color: var(--color-on-dark);">
        Marketing for firms with something complicated to sell.
      </h1>
      <p class="hero-line text-lg md:text-xl max-w-3xl leading-relaxed mb-6" data-line="2" style="color: var(--color-on-dark);">
        I'm the marketing person who'll also build the dashboard. Half the day is writing copy, briefing creative, or working through compliance edits. The other half is in SQL or Python, untangling why the numbers don't agree with whatever deck claims they should.
      </p>
      <p class="hero-line text-lg md:text-xl max-w-2xl leading-relaxed mb-12" data-line="3" style="color: var(--color-on-dark-soft);">
        Currently running digital marketing at Evolve ETFs. Before that, similar roles at Greybrook Realty Partners, Clifton Blake, and Roxborough Communities, plus consulting for a few consumer brands. Mostly financial services so far; tech is where I'd like to spend more of the next stretch.
      </p>
      <div class="hero-line flex flex-wrap gap-6 items-center" data-line="4">
        <a
          href="/work"
          class="inline-flex items-center gap-2 bg-accent text-paper px-6 py-3 text-sm font-medium hover:bg-accent-warm transition-colors"
        >
          See work
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="mailto:justindoone@gmail.com"
          class="link-underline text-sm hover:text-accent transition-colors"
          style="color: var(--color-on-dark-soft);"
        >
          justindoone@gmail.com
        </a>
      </div>
    </div>
  </section>

  <!-- SELECTED WORK (light) -->
  <section class="mx-auto max-w-7xl px-6 lg:px-12 pt-20 md:pt-28 pb-20">
    <div class="flex items-end justify-between mb-8" data-reveal>
      <div>
        <p class="eyebrow mb-3">Recent work</p>
        <h2 class="heading-display text-4xl md:text-5xl text-ink">
          Case studies
        </h2>
      </div>
      <a
        href="/work"
        class="hidden md:inline-block text-sm text-ink-soft link-underline hover:text-accent transition-colors"
      >
        View all →
      </a>
    </div>

    <div>
      {
        showcase.map((entry, i) => (
          <div data-reveal data-reveal-delay={Math.min(i + 1, 4)}>
            <WorkCard
              title={entry.data.title}
              client={entry.data.client}
              role={entry.data.role}
              date={entry.data.date}
              summary={entry.data.summary}
              href={`/work/${entry.id}`}
              tags={entry.data.tags}
              accent={entry.data.accent}
              cover={entry.data.cover}
              index={i}
            />
          </div>
        ))
      }
      <div class="border-t border-rule"></div>
    </div>

    <div class="mt-12 md:hidden">
      <a
        href="/work"
        class="text-sm text-ink-soft link-underline hover:text-accent transition-colors"
      >
        View all work →
      </a>
    </div>
  </section>

  <!-- CTA (dark) -->
  <section class="dark-section relative py-24 md:py-32" data-reveal>
    <div class="hero-orb" style="top: 20%; right: -5%; opacity: 0.3;"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12">
      <p class="eyebrow mb-6">Currently</p>
      <p class="heading-display text-3xl md:text-5xl max-w-4xl leading-tight" style="color: var(--color-on-dark);">
        Open to consulting work and the right in-house role.
      </p>
      <a
        href="mailto:justindoone@gmail.com"
        class="inline-flex items-center gap-2 mt-10 bg-accent text-paper px-6 py-3 text-sm font-medium hover:bg-accent-warm transition-colors"
      >
        Start a conversation
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
