---
import FaqMockupLayout from '../../layouts/FaqMockupLayout.astro';
import faqs from '../../data/faqs.json';
import hero from '../../data/faqs-hero.json';

interface Topic {
  slug: string;
  title: string;
  blurb: string;
  questions: string[];
  image_url?: string;
}
const topics = faqs as unknown as Topic[];
---

<FaqMockupLayout
  title="FAQs - Evolve ETFs (Mockup)"
  pageHeading="FAQs"
  heroImage={hero.hub_hero_image}
>
  <!-- Mirrors the live evolveetfs.com/faqs/ hub markup exactly: product-filters
       toolbar with grid/list view toggle, then a grid of .news-single cards
       with featured images + a list-view alternative. -->

  <div id="product-filters">
    <div class="container no-overflow">
      <div class="row flex-md-row-reverse">
        <div id="view-modes" class="col col-12 col-lg-4 archive-view">
          <div class="row">
            <div class="button-col">
              <button data-view-mode="grid" class="active" type="button">
                <svg xmlns="http://www.w3.org/2000/svg" width="14.5" height="14.494" viewBox="0 0 14.5 14.494">
                  <g transform="translate(0.045 0.045)">
                    <rect width="5.348" height="5.346" rx="1" transform="translate(0.705 8.353)" fill="none" stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                    <rect width="5.348" height="5.346" rx="1" transform="translate(8.357 8.353)" fill="none" stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                    <rect width="5.348" height="5.347" rx="1" transform="translate(0.705 0.705)" fill="none" stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                    <rect width="5.348" height="5.347" rx="1" transform="translate(8.357 0.705)" fill="none" stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                  </g>
                </svg>
                <span class="p">Grid View</span>
              </button>
            </div>
            <div class="button-col">
              <button data-view-mode="list" class="" type="button">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14">
                  <g>
                    <line x1="3" y1="2" x2="14" y2="2" fill="none" stroke="#fff" stroke-linecap="round" stroke-width="1.5"/>
                    <line x1="3" y1="7" x2="14" y2="7" fill="none" stroke="#fff" stroke-linecap="round" stroke-width="1.5"/>
                    <line x1="3" y1="12" x2="14" y2="12" fill="none" stroke="#fff" stroke-linecap="round" stroke-width="1.5"/>
                    <circle cx="0.75" cy="2" r="0.75" fill="#fff"/>
                    <circle cx="0.75" cy="7" r="0.75" fill="#fff"/>
                    <circle cx="0.75" cy="12" r="0.75" fill="#fff"/>
                  </g>
                </svg>
                <span class="p">List View</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container page-content">
    <div class="row">
      <div class="grid-view blog-grid" id="grid-view">
        {topics.map((t) => (
          <div class="news-single col col-12 col-md-4 col-sm-6">
            <div class="image-container">
              <div
                class="featured-image"
                style={t.image_url ? `background-image: url('${t.image_url}'); background-size: cover; background-position: center;` : ''}
              ></div>
            </div>
            <a class="news-single-container white-box" href={`/faqs/${t.slug}/`} target="_self">
              <h3 set:html={t.title} />
              <h4 class="read-pop">READ MORE</h4>
            </a>
          </div>
        ))}
      </div>

      <div class="list-view blog-list" id="list-view" style="display: none;">
        {topics.map((t) => (
          <div class="news-single col-12">
            <a class="news-single-container white-box" href={`/faqs/${t.slug}/`} target="_self">
              <div class="row">
                <div class="col col-7 col-sm-9">
                  <h3 set:html={t.title} />
                </div>
                <div class="col col-5 col-sm-3">
                  <h4 class="read-pop">READ MORE</h4>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script is:inline>
    // Grid/list view toggle (the live site has full theme JS; here's the minimum)
    (function () {
      const buttons = document.querySelectorAll('#view-modes button[data-view-mode]');
      const grid = document.getElementById('grid-view');
      const list = document.getElementById('list-view');
      buttons.forEach((b) => {
        b.addEventListener('click', () => {
          const mode = b.getAttribute('data-view-mode');
          buttons.forEach((x) => x.classList.toggle('active', x === b));
          if (mode === 'grid') { grid.style.display = ''; list.style.display = 'none'; }
          else { grid.style.display = 'none'; list.style.display = ''; }
        });
      });
    })();
  </script>
</FaqMockupLayout>
