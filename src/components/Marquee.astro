---
const items = [
  'Evolve ETFs',
  'Greybrook Realty Partners',
  'Clifton Blake',
  'Roxborough Communities',
  'Cricket Park',
  'Saturnbird',
  'minihotel.hk',
];
---

<div class="marquee py-10 rule-top border-b border-rule">
  <div class="marquee-track">
    {
      [...items, ...items].map((item) => (
        <span class="inline-flex items-center gap-10 pr-10 font-serif text-2xl md:text-3xl text-ink-soft">
          <span>{item}</span>
          <span class="text-accent text-base" aria-hidden="true">
            ●
          </span>
        </span>
      ))
    }
  </div>
</div>
