---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const links = [
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header
  class="sticky top-0 z-40 backdrop-blur-md"
  style="background-color: rgb(20 22 26 / 0.9); color: var(--color-on-dark);"
>
  <div class="mx-auto max-w-7xl px-6 lg:px-12">
    <nav
      class="flex h-20 items-center justify-between"
      style="border-bottom: 1px solid var(--color-rule-dark);"
      aria-label="Primary"
    >
      <a
        href="/"
        aria-label="Justin Doone"
        class="hover:opacity-80 transition-opacity"
        style="display: block; width: 56px; height: 40px; background-image: url('/logos/logo-mark.png?v=4'); background-size: contain; background-position: center; background-repeat: no-repeat;"
      ></a>
      <ul class="flex items-center gap-8 text-sm">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'transition-colors hover:text-accent',
                  isActive(link.href) ? 'font-medium' : '',
                ]}
                style={
                  isActive(link.href)
                    ? 'color: var(--color-on-dark);'
                    : 'color: var(--color-on-dark-soft);'
                }
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
