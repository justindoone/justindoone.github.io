---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const links = [
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-40 bg-paper/85 backdrop-blur-sm">
  <div class="mx-auto max-w-7xl px-6 lg:px-12">
    <nav
      class="flex h-16 items-center justify-between border-b border-rule"
      aria-label="Primary"
    >
      <a
        href="/"
        class="text-ink font-serif text-xl tracking-tight hover:text-accent transition-colors"
      >
        Justin Doone
      </a>
      <ul class="flex items-center gap-8 text-sm">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'transition-colors hover:text-accent',
                  isActive(link.href)
                    ? 'text-ink font-medium'
                    : 'text-ink-soft',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
