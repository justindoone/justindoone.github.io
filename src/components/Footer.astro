---
const year = new Date().getFullYear();
---

<footer class="dark-section mt-24 relative">
  <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16 relative z-10">
    <div class="grid gap-8 md:grid-cols-3 md:items-end">
      <div>
        <p class="eyebrow mb-3">Get in touch</p>
        <a
          href="mailto:justindoone@gmail.com"
          class="font-serif text-2xl link-underline transition-colors hover:text-accent"
          style="color: var(--color-on-dark);"
        >
          justindoone@gmail.com
        </a>
      </div>
      <div>
        <p class="eyebrow mb-3">Elsewhere</p>
        <ul class="space-y-1.5" style="color: var(--color-on-dark-soft);">
          <li>
            <a
              href="https://www.linkedin.com/in/jdoone"
              target="_blank"
              rel="noopener"
              class="link-underline hover:text-accent transition-colors"
              >LinkedIn</a
            >
          </li>
        </ul>
      </div>
      <div class="md:text-right text-sm" style="color: var(--color-on-dark-mute);">
        <p>Toronto, ON</p>
        <p>© {year} Justin Doone</p>
      </div>
    </div>
  </div>
</footer>
