---
interface Props {
  title: string;
  client: string;
  role: string;
  date: string;
  summary: string;
  href: string;
  tags: string[];
  accent?: string;
  index: number;
}

const {
  title,
  client,
  role,
  date,
  summary,
  href,
  tags,
  accent = '#b34a2a',
  index,
} = Astro.props;

const num = String(index + 1).padStart(2, '0');
---

<a
  href={href}
  class="group block rule-top py-8 md:py-10 transition-colors"
  style={`--accent: ${accent};`}
>
  <div class="grid md:grid-cols-12 gap-6 md:gap-10 items-start">
    <div class="md:col-span-1 eyebrow pt-2">{num}</div>

    <div class="md:col-span-7">
      <p class="eyebrow mb-2 flex flex-wrap gap-x-3 gap-y-1">
        <span>{client}</span>
        <span class="text-rule">/</span>
        <span>{date}</span>
      </p>
      <h3
        class="heading-display text-3xl md:text-4xl text-ink mb-3 transition-colors group-hover:text-accent"
        style="transition: color 0.25s ease;"
      >
        {title}
      </h3>
      <p class="text-ink-soft max-w-prose leading-relaxed">{summary}</p>
    </div>

    <div class="md:col-span-3 flex flex-wrap gap-1.5 md:pt-2">
      {
        tags.map((tag) => (
          <span class="text-xs text-ink-mute border border-rule rounded-full px-2.5 py-0.5">
            {tag}
          </span>
        ))
      }
    </div>

    <div class="md:col-span-1 md:text-right pt-2">
      <span
        class="inline-block text-ink-mute group-hover:text-accent group-hover:translate-x-1 transition-all"
        aria-hidden="true">→</span
      >
    </div>
  </div>
</a>
