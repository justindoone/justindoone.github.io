---
interface Props {
  title: string;
  client: string;
  role: string;
  date: string;
  summary: string;
  href: string;
  tags: string[];
  accent?: string;
  accentSecondary?: string;
  cover?: string;
  cardCover?: string;
  index: number;
}

const {
  title,
  client,
  role,
  date,
  summary,
  href,
  tags,
  accent = '#1d1f24',
  accentSecondary,
  cover,
  cardCover,
  index,
} = Astro.props;

const displayCover = cardCover ?? cover;

const num = String(index + 1).padStart(2, '0');
---

<a
  href={href}
  class="work-card group block rule-top py-8 md:py-10"
  style={`--accent: ${accent}; --accent-secondary: ${accentSecondary ?? accent};`}
>
  <span class="work-card-bar"></span>
  <div class="work-card-inner grid md:grid-cols-12 gap-6 md:gap-8 items-center">
    <div class="md:col-span-1 eyebrow self-start pt-2" style="color: var(--accent-secondary);">{num}</div>

    <div class="md:col-span-3 relative">
      <div class="aspect-[4/3] overflow-hidden rounded-sm bg-paper-soft">
        {
          displayCover ? (
            <img
              src={displayCover}
              alt={title}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              style="background-color: var(--accent);"
            />
          ) : (
            <div
              class="w-full h-full relative flex items-center justify-center px-4"
              style="background-color: var(--accent);"
            >
              <div
                class="absolute inset-0 opacity-30"
                style="background-image: radial-gradient(circle at 1px 1px, rgba(240,235,225,0.08) 1px, transparent 0); background-size: 14px 14px;"
              />
              <span class="relative font-serif text-xl md:text-2xl text-center leading-tight text-on-dark">
                {client}
              </span>
            </div>
          )
        }
      </div>
    </div>

    <div class="md:col-span-7">
      <p class="eyebrow mb-2 flex flex-wrap gap-x-3 gap-y-1">
        <span>{client}</span>
        <span class="text-rule">/</span>
        <span>{date}</span>
      </p>
      <h3
        class="heading-display text-3xl md:text-4xl text-ink mb-3 transition-colors duration-300 group-hover:text-[var(--accent-secondary)]"
      >
        {title}
      </h3>
      <p class="text-ink-soft max-w-prose leading-relaxed">{summary}</p>
    </div>

    <div class="md:col-span-1 md:text-right">
      <span
        class="inline-block text-ink-mute text-xl transition-all duration-300 group-hover:text-[var(--accent-secondary)] group-hover:translate-x-2"
        aria-hidden="true"
      >
        →
      </span>
    </div>
  </div>
</a>
